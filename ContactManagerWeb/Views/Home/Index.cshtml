@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    
    <title>Inicio — ContactManager Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            /* PALETA ESTRICTAMENTE MORADA */
            --bg: #07040D;
            --bg-card: rgba(30, 20, 45, 0.4);
            --accent: #8B5CF6;
            --accent-light: #C4B5FD;
            --accent-dark: #5B21B6;
            --accent-glow: rgba(139, 92, 246, 0.3); /* Resplandor suavizado */
            --text-muted: #9CA3AF;
            --border: rgba(255, 255, 255, 0.1);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; }

        body {
            background-color: var(--bg);
            color: white;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            /* SE ELIMINÓ EL CURSOR CROSSHAIR DE AQUÍ */
        }

        /* CUADRÍCULA DE FONDO */
        body::before {
            content: ''; position: absolute; inset: 0;
            background-image: 
                linear-gradient(rgba(139, 92, 246, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(139, 92, 246, 0.03) 1px, transparent 1px);
            background-size: 40px 40px; z-index: -2; pointer-events: none;
        }

        /* LUCES AMBIENTALES */
        .ambient-light {
            position: absolute; border-radius: 50%; filter: blur(140px);
            z-index: -1; pointer-events: none; opacity: 0.3; /* Luces más tenues */
        }
        .light-1 { top: -10%; left: -10%; width: 500px; height: 500px; background: var(--accent-dark); }
        .light-2 { bottom: -20%; right: 10%; width: 600px; height: 600px; background: #4C1D95; }

        /* --- OVERLAY DE TRANSICIÓN RÁPIDA Y SUTIL --- */
        .page-transition-overlay {
            position: fixed; inset: 0;
            background: rgba(7, 4, 13, 0.98); 
            backdrop-filter: blur(10px);
            z-index: 99999;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease; /* TIEMPO SÚPER RÁPIDO */
        }
        body.access-granted .page-transition-overlay { opacity: 1; }

        /* --- NAVBAR --- */
        .navbar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 30px 60px; position: absolute; top: 0; width: 100%; z-index: 100;
        }

        .brand-name {
            font-weight: 800; font-size: 1.5rem; letter-spacing: -0.5px;
            color: white; text-decoration: none; display: flex; align-items: center; gap: 12px;
            cursor: pointer; transition: all 0.3s ease; padding: 10px 18px;
            border-radius: 16px; border: 1px solid transparent; position: relative; z-index: 101;
        }
        .brand-name:hover {
            background: rgba(139, 92, 246, 0.05); border-color: rgba(139, 92, 246, 0.2);
            transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }
        .brand-name span.dot { color: var(--accent); }

        .team-badge {
            font-weight: 800; color: var(--accent-light); font-size: 0.8rem; letter-spacing: 2px;
            background: rgba(139, 92, 246, 0.1); padding: 10px 20px; border-radius: 20px;
            border: 1px solid rgba(139, 92, 246, 0.2); box-shadow: 0 0 15px rgba(139, 92, 246, 0.1);
        }

        /* --- HERO SECTION --- */
        .hero-container {
            display: flex; align-items: center; justify-content: space-between;
            max-width: 1300px; margin: auto; padding: 0 50px; height: 100%; gap: 80px;
            position: absolute; inset: 0; z-index: 10;
        }

        .hero-text { flex: 1.1; animation: slideInLeft 1s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; pointer-events: none; transition: all 0.4s ease; }
        body.access-granted .hero-text { transform: translateX(-40px); opacity: 0; filter: blur(5px); }
        
        h1 { font-size: 4.5rem; font-weight: 800; line-height: 1.1; letter-spacing: -2px; margin-bottom: 25px; }
        h1 .highlight {
            background: linear-gradient(135deg, #FFFFFF, var(--accent));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            text-shadow: 0 0 40px var(--accent-glow);
        }

        p.subtitle {
            color: var(--text-muted); font-size: 1.25rem; margin-bottom: 50px;
            line-height: 1.6; max-width: 520px; font-weight: 400;
        }

        /* --- ACCESO SIN BOTONES --- */
        .access-hint {
            display: inline-flex; align-items: center; gap: 15px; font-size: 1.1rem;
            color: var(--accent-light); font-weight: 500; animation: breathe 2.5s infinite ease-in-out;
        }

        .pulse-dot {
            width: 12px; height: 12px; background: var(--accent); border-radius: 50%;
            box-shadow: 0 0 15px var(--accent), 0 0 30px var(--accent); animation: pulseFast 1s infinite alternate;
        }

        kbd {
            background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255,255,255,0.2);
            padding: 5px 12px; border-radius: 8px; font-family: inherit; font-size: 0.95rem;
            font-weight: 700; color: white; box-shadow: 0 4px 0 rgba(255,255,255,0.1);
        }

        /* --- TARJETA FLOTANTE (4 CONTACTOS MÁS GRANDES) --- */
        .hero-visual { flex: 0.9; position: relative; height: 500px; display: flex; justify-content: center; align-items: center; perspective: 1200px; pointer-events: none; }
        
        .abstract-orb { position: absolute; border-radius: 50%; background: radial-gradient(circle at 30% 30%, var(--accent-light), var(--accent-dark)); box-shadow: 0 0 50px var(--accent-glow); animation: floatOrb 6s infinite ease-in-out alternate; transition: all 0.4s ease; }
        .orb-1 { width: 120px; height: 120px; top: 5%; right: 10%; animation-delay: 0s; }
        .orb-2 { width: 80px; height: 80px; bottom: 8%; left: 5%; animation-delay: -3s; }

        body.access-granted .abstract-orb { transform: scale(0); opacity: 0; }

        .abstract-glass {
            position: relative; width: 360px; height: 480px; background: rgba(30, 15, 50, 0.4);
            border: 1px solid rgba(139, 92, 246, 0.2); border-radius: 30px;
            backdrop-filter: blur(15px); box-shadow: 0 30px 60px rgba(0,0,0,0.5);
            display: flex; flex-direction: column; justify-content: space-between; padding: 40px 30px;
            animation: floatMain 5s infinite ease-in-out; z-index: 2;
            transition: all 0.4s ease-out; /* Transición súper rápida */
        }

        body.access-granted .abstract-glass { transform: scale(1.05) translateY(-20px) rotate(2deg); opacity: 0; filter: blur(5px); }

        .glass-line {
            width: 100%; height: 75px; /* Más altos */
            background: rgba(255,255,255,0.03);
            border-radius: 18px; border: 1px solid rgba(255,255,255,0.05);
            display: flex; align-items: center; padding: 0 20px; gap: 18px;
        }

        .g-avatar { width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, var(--accent-light), var(--accent-dark)); }
        .g-text-1 { width: 60%; height: 10px; background: rgba(255,255,255,0.2); border-radius: 5px; }
        .g-text-2 { width: 40%; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; margin-top: 10px;}

        /* Animaciones base */
        @@keyframes floatMain { 0% { transform: translateY(0px) rotate(2deg); } 50% { transform: translateY(-20px) rotate(-1deg); } 100% { transform: translateY(0px) rotate(2deg); } }
        @@keyframes floatOrb { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(-20px, 20px) scale(1.1); } }
        @@keyframes slideInLeft { from { opacity: 0; transform: translateX(-60px); } to { opacity: 1; transform: translateX(0); } }
        @@keyframes breathe { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
        @@keyframes pulseFast { 0% { transform: scale(0.8); opacity: 0.5; } 100% { transform: scale(1.2); opacity: 1; } }

        /* --- MODAL DEL EQUIPO --- */
        .team-modal-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(15px);
            z-index: 9999; display: flex; align-items: center; justify-content: center;
            opacity: 0; visibility: hidden; transition: all 0.4s; cursor: default;
        }
        .team-modal-overlay.active { opacity: 1; visibility: visible; }
        .team-modal-content {
            background: rgba(15, 10, 25, 0.9); border: 1px solid var(--accent-dark); border-radius: 30px;
            padding: 50px; width: 100%; max-width: 800px; transform: translateY(50px) scale(0.95);
            transition: all 0.4s; position: relative; box-shadow: 0 40px 100px rgba(0,0,0,0.9), inset 0 0 40px rgba(139,92,246,0.1);
        }
        .team-modal-overlay.active .team-modal-content { transform: translateY(0) scale(1); }
        .close-modal { position: absolute; top: 25px; right: 30px; background: rgba(255,255,255,0.05); border: none; color: white; font-size: 1.5rem; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; transition: 0.3s; }
        .close-modal:hover { background: #FF4444; transform: rotate(90deg); }
        .team-modal-content h2 { font-size: 2.5rem; font-family: 'DM Serif Display', serif; margin-bottom: 5px; text-align: center; }
        .team-modal-content p.t-sub { text-align: center; color: var(--accent-light); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; font-size: 0.85rem; margin-bottom: 40px; }
        .team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .team-card { background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 20px; border-radius: 20px; display: flex; align-items: center; gap: 15px; transition: 0.3s; }
        .team-card:hover { background: rgba(139, 92, 246, 0.1); border-color: var(--accent); transform: translateY(-5px); }
        .team-avatar { width: 50px; height: 50px; border-radius: 15px; background: linear-gradient(135deg, var(--bg), var(--accent)); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
        .team-info h4 { margin: 0 0 3px 0; font-size: 1.1rem; }
        .team-info span { font-size: 0.8rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; }

        @@media (max-width: 900px) {
            .hero-container { flex-direction: column; text-align: center; padding-top: 120px; overflow-y: auto; }
            h1 { font-size: 3.2rem; }
            p.subtitle { margin: 0 auto 40px auto; }
            .hero-visual { display: none; }
            .team-modal-content { padding: 30px 20px; }
        }
    </style>
</head>
<body>

    <div class="ambient-light light-1"></div>
    <div class="ambient-light light-2"></div>

    <nav class="navbar">
        <div class="brand-name" id="logoTrigger" title="Conoce a los creadores">
            <span style="font-size:1.8rem;">📒</span> ContactManager<span class="dot">.</span>
        </div>
        <div class="team-badge">PROYECTO FINAL - G8</div>
    </nav>

    <div class="hero-container" id="interactionZone">
        <div class="hero-text">
            <h1>Domina tu agenda <br> de forma <span class="highlight">inteligente</span>.</h1>
            <p class="subtitle">Una experiencia fluida y rápida diseñada para categorizar, buscar y administrar tus contactos sin fricción.</p>

            <div class="access-hint" id="hintText">
                <span class="pulse-dot"></span>
                <span>Presiona <kbd>ESPACIO</kbd> o haz clic para acceder</span>
            </div>
        </div>

        <div class="hero-visual">
            <div class="abstract-orb orb-1"></div>
            <div class="abstract-orb orb-2"></div>
            
            <div class="abstract-glass" id="abstractCard">
                <div class="glass-line">
                    <div class="g-avatar"></div>
                    <div style="flex:1"><div class="g-text-1"></div><div class="g-text-2"></div></div>
                </div>
                <div class="glass-line" style="opacity: 0.8;">
                    <div class="g-avatar"></div>
                    <div style="flex:1"><div class="g-text-1" style="width: 40%"></div><div class="g-text-2" style="width: 70%"></div></div>
                </div>
                <div class="glass-line" style="opacity: 0.5;">
                    <div class="g-avatar"></div>
                    <div style="flex:1"><div class="g-text-1" style="width: 80%"></div><div class="g-text-2" style="width: 50%"></div></div>
                </div>
                <div class="glass-line" style="opacity: 0.2;">
                    <div class="g-avatar"></div>
                    <div style="flex:1"><div class="g-text-1" style="width: 50%"></div><div class="g-text-2" style="width: 80%"></div></div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="page-transition-overlay"></div>

    <div class="team-modal-overlay" id="teamModal">
        <div class="team-modal-content">
            <button class="close-modal" id="closeTeamBtn">×</button>
            <h2>Los Creadores</h2>
            <p class="t-sub">Desarrolladores del Equipo 8</p>
            
            <div class="team-grid">
                <div class="team-card">
                    <div class="team-avatar">👨‍💻</div>
                    <div class="team-info"><h4>Nombre Apellido 1</h4><span>Fullstack Developer</span></div>
                </div>
                <div class="team-card">
                    <div class="team-avatar">👩‍💻</div>
                    <div class="team-info"><h4>Nombre Apellido 2</h4><span>UI / UX Design</span></div>
                </div>
                <div class="team-card">
                    <div class="team-avatar">👨‍💻</div>
                    <div class="team-info"><h4>Nombre Apellido 3</h4><span>Database Admin</span></div>
                </div>
                <div class="team-card">
                    <div class="team-avatar">👩‍💻</div>
                    <div class="team-info"><h4>Nombre Apellido 4</h4><span>QA & Testing</span></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let accessing = false;
        const hintText = document.getElementById('hintText');

        // FUNCIÓN MAGICA DE ACCESO (AHORA MÁS RÁPIDA)
        function triggerSystemAccess() {
            if (accessing) return; // Evitar doble ejecución
            accessing = true;

            // Cambia el texto
            hintText.innerHTML = `<span class="pulse-dot" style="background:#FFF; box-shadow:0 0 20px #FFF"></span> <span style="color:#FFF">Inicializando Sistema...</span>`;
            
            // Agrega la clase que desencadena la nueva transición rápida
            document.body.classList.add('access-granted');

            // Redirigir a la agenda en solo 400ms (súper ágil)
            setTimeout(() => {
                // Truco JS adicional para re-forzar ignorar el caché desde el cliente:
                window.location.replace('@Url.Action("Index", "Contactos")');
            }, 400);
        }

        // ESCUCHAR TECLA ESPACIO
        document.addEventListener('keydown', function(event) {
            // Ignorar si el modal está abierto
            if (document.getElementById('teamModal').classList.contains('active')) return;
            
            if (event.code === 'Space' || event.code === 'Enter') {
                triggerSystemAccess();
            }
        });

        // ESCUCHAR CLICS EN LA PANTALLA
        document.getElementById('interactionZone').addEventListener('click', function(event) {
            triggerSystemAccess();
        });

        // LÓGICA DEL MODAL DEL EQUIPO
        const logo = document.getElementById('logoTrigger');
        const modal = document.getElementById('teamModal');
        const closeBtn = document.getElementById('closeTeamBtn');

        logo.addEventListener('click', (e) => { 
            e.stopPropagation(); // Evita que se dispare el acceso al sistema
            modal.classList.add('active'); 
        });
        
        closeBtn.addEventListener('click', (e) => { 
            e.stopPropagation();
            modal.classList.remove('active'); 
        });
        
        modal.addEventListener('click', (e) => { 
            if(e.target === modal) {
                e.stopPropagation();
                modal.classList.remove('active'); 
            }
        });
    </script>

</body>
</html>