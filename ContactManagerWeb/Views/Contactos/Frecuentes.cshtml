@model IEnumerable<ContactManagerWeb.Models.Contacto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Contactos Frecuentes";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />

<style>
    :root {
        --bg-main: #171721;
        --bg-card: #20202B;
        --text-white: #FFFFFF;
        --text-muted: #8A8A9E;
        --border-color: #2D2D3D;
        --accent: #5A4FCF;
        --accent-glow: rgba(90, 79, 207, 0.4);
    }

    /* Animaciones Premium */
    @@keyframes floatUp {
        0% { opacity: 0; transform: translateY(40px); }
        100% { opacity: 1; transform: translateY(0); }
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .page-wrapper { 
        font-family: 'DM Sans', sans-serif; 
        padding: 40px; 
        color: var(--text-white); 
        animation: fadeIn 0.8s ease-out;
    }
    
    /* Botón de retroceso Pro */
    .btn-back { 
        display: inline-flex; align-items: center; gap: 10px; 
        color: var(--text-muted); text-decoration: none; 
        font-weight: 600; font-size: 0.9rem; letter-spacing: 0.5px;
        margin-bottom: 30px; transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1); 
        padding: 8px 15px; border-radius: 20px;
        background: rgba(255,255,255,0.03); border: 1px solid transparent;
    }
    .btn-back:hover { 
        color: var(--text-white); transform: translateX(-8px); 
        background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.1);
    }

    /* Título con gradiente de luz */
    .page-title { 
        font-family: 'DM Serif Display', serif; font-size: 2.8rem; margin-bottom: 10px; 
        background: linear-gradient(135deg, #E2D4FF 0%, #9D88FF 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        animation: floatUp 0.6s ease-out forwards;
    }
    .page-subtitle {
        color: var(--text-muted); font-size: 1.1rem;
        animation: floatUp 0.7s ease-out forwards; opacity: 0;
    }

    /* Grid y Tarjetas */
    .contacts-grid { 
        display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; margin-top: 40px; 
    }
    
    .c-card { 
        background: linear-gradient(180deg, var(--bg-card) 0%, rgba(28,28,38,0.8) 100%);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border-color); border-radius: 16px; 
        padding: 20px 25px; display: flex; align-items: center; gap: 18px; 
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        opacity: 0; animation: floatUp 0.6s ease-out forwards;
    }
    
    /* Brillo en Hover */
    .c-card:hover { 
        border-color: #6B5BFF; 
        transform: translateY(-8px) scale(1.02); 
        box-shadow: 0 15px 35px var(--accent-glow), inset 0 1px 0 rgba(255,255,255,0.1); 
    }
    
    .sm-avatar { 
        width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; 
        font-weight: 700; font-size: 1.1rem; color: white; 
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }
    .c-card:hover .sm-avatar { transform: rotate(-15deg) scale(1.1); }
    
    .c-info { flex: 1; }
    .c-name { font-weight: 600; margin-bottom: 4px; font-size: 1.1rem; color: var(--text-white); letter-spacing: 0.3px; }
    .c-phone { color: var(--text-muted); font-size: 0.85rem; display: flex; align-items: center; gap: 5px;}
    .c-star { 
        background: rgba(251, 191, 36, 0.1); border: 1px solid rgba(251, 191, 36, 0.3); 
        color: #FBBF24; font-size: 1rem; width: 35px; height: 35px; 
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 15px rgba(251, 191, 36, 0.15);
    }
</style>

<div class="page-wrapper">
    <a asp-action="Index" class="btn-back">
        <span style="font-size:1.2rem;">←</span> Volver a la Agenda
    </a>

    <h1 class="page-title">Contactos Frecuentes</h1>
    <p class="page-subtitle">Tus conexiones más importantes, a un clic de distancia.</p>

    @if (!Model.Any())
    {
        <div style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.1); padding: 40px; border-radius: 16px; text-align: center; margin-top: 40px; color: var(--text-muted); animation: floatUp 0.8s ease forwards; opacity: 0;">
            Aún no tienes contactos marcados con la estrella. ¡Empieza a destacar tus favoritos!
        </div>
    }
    else
    {
        <div class="contacts-grid">
            @{ int delay = 1; }
            @foreach (var contact in Model)
            {
                <div class="c-card" style="animation-delay: @(delay * 0.1)s;">
                    @{ 
                        var colors = new[] { 
                            "linear-gradient(135deg, #4A5568 0%, #2D3748 100%)", /* Gris Azulado Mate */
                            "linear-gradient(135deg, #553C9A 0%, #322659 100%)", /* Morado Profundo */
                            "linear-gradient(135deg, #2C7A7B 0%, #234E52 100%)", /* Esmeralda Oscuro */
                            "linear-gradient(135deg, #975A16 0%, #744210 100%)", /* Bronce Elegante */
                            "linear-gradient(135deg, #2B6CB0 0%, #2A4365 100%)"  /* Azul Marino */
}; 
                        var bg = colors[Math.Abs(contact.Nombre.GetHashCode()) % colors.Length]; 
                    }
                    <div class="sm-avatar" style="background: @bg;">
                        @(contact.Nombre.Length >= 2 ? contact.Nombre.Substring(0, 2).ToUpper() : contact.Nombre.ToUpper())
                    </div>
                    <div class="c-info">
                        <div class="c-name">@contact.Nombre</div>
                        <div class="c-phone">📞 @contact.Telefono</div>
                    </div>
                    <div class="c-star">★</div>
                </div>
                delay++;
            }
        </div>
    }
</div>