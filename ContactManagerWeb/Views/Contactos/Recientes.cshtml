@model IEnumerable<ContactManagerWeb.Models.Contacto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Agregados Recientemente";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agregados Recientemente — Agenda Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
            :root {
                --bg-main: #0B0B10;
                --bg-card: rgba(28, 28, 38, 0.5);
                --text-white: #FFFFFF;
                --text-muted: #8A8A9E;
                --border-color: rgba(255, 255, 255, 0.08);
                --accent: #6B5BFF;
                --accent-glow: rgba(107, 91, 255, 0.35);
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
                font-family: 'DM Sans', sans-serif;
            }

            body {
                background-color: var(--bg-main);
                background-image: radial-gradient(circle at 50% 50%, rgba(107, 91, 255, 0.05), transparent 50%);
                color: var(--text-white);
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                overflow-x: hidden;
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* --- NAVBAR --- */
            .navbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px 50px;
                background: rgba(15, 15, 20, 0.7);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border-bottom: 1px solid var(--border-color);
                position: sticky;
                top: 0;
                z-index: 100;
                animation: fadeUp 0.6s ease-out forwards;
            }

            .nav-brand {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
            }

            .brand-icon {
                background: linear-gradient(135deg, #9D88FF, #6B5BFF);
                width: 32px;
                height: 32px;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                box-shadow: 0 4px 12px var(--accent-glow);
            }

            .brand-name {
                font-weight: 800;
                font-size: 1.25rem;
                letter-spacing: 0.5px;
                background: linear-gradient(135deg, #FFFFFF, #A396FF);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            /* TABS */
            .tab-row {
                display: flex;
                gap: 6px;
                background: rgba(0, 0, 0, 0.4);
                padding: 6px;
                border-radius: 16px;
                border: 1px solid rgba(255, 255, 255, 0.05);
                box-shadow: inset 0 4px 10px rgba(0,0,0,0.5);
            }

            .tab {
                color: #8A8A9E;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.9rem;
                padding: 10px 20px;
                border-radius: 12px;
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .tab:hover {
                    color: white;
                    background: rgba(255,255,255,0.03);
                    transform: translateY(-2px);
                }

                .tab.active {
                    background: linear-gradient(135deg, var(--accent), #8375FF);
                    color: white;
                    box-shadow: 0 6px 20px rgba(107, 91, 255, 0.4);
                    transform: translateY(-2px);
                }

            /* --- CONTENIDO --- */
            .main-content {
                flex: 1;
                padding: 60px 40px;
                max-width: 1200px;
                margin: 0 auto;
                width: 100%;
            }

            .header-section {
                text-align: center;
                margin-bottom: 50px;
            }

            .page-title {
                font-size: 2.8rem;
                font-weight: 800;
                letter-spacing: -1px;
                margin-bottom: 15px;
                color: var(--text-white);
                animation: fadeUp 0.6s ease-out forwards;
            }

            .page-subtitle {
                color: #D1D1E0;
                font-size: 1.1rem;
                line-height: 1.6;
                max-width: 700px;
                margin: 0 auto;
                animation: fadeUp 0.7s ease-out forwards;
                opacity: 0;
            }

            .contacts-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
                gap: 20px;
            }

            .fav-card, .c-card {
                position: relative;
                border-radius: 18px;
                padding: 20px;
                display: flex;
                align-items: center;
                gap: 15px;
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                opacity: 0;
                animation: fadeUp 0.6s ease-out forwards;
                backdrop-filter: blur(12px);
            }

            .fav-card {
                background: linear-gradient(145deg, rgba(42, 35, 82, 0.7), var(--bg-card));
                border: 1px solid rgba(123, 107, 255, 0.2);
            }

            .c-card {
                background-color: var(--bg-card);
                border: 1px solid var(--border-color);
            }

                .fav-card:hover, .c-card:hover {
                    transform: translateY(-6px);
                }

            .avatar-box {
                width: 50px;
                height: 50px;
                border-radius: 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.2rem;
                font-weight: 800;
                flex-shrink: 0;
            }

            .star-fav {
                color: #FBBF24;
                font-size: 1.3rem;
                margin-left: auto;
                text-shadow: 0 0 10px rgba(251, 191, 36, 0.5);
            }

            .fav-name, .c-name {
                font-size: 1.05rem;
                font-weight: 700;
                color: white;
                margin-bottom: 4px;
            }

            .fav-detail, .c-phone {
                color: var(--text-muted);
                font-size: 0.9rem;
            }

            .dropdown {
                position: relative;
                display: inline-block;
                margin-left: 10px;
            }

            .dropdown-btn {
                background: transparent;
                border: none;
                color: var(--text-muted);
                font-size: 1.5rem;
                cursor: pointer;
                font-weight: bold;
                padding: 0 5px;
            }

            .dropdown-content {
                display: none;
                position: absolute;
                right: 0;
                bottom: 100%;
                background-color: rgba(20, 20, 28, 0.98);
                min-width: 170px;
                border: 1px solid var(--border-color);
                border-radius: 12px;
                overflow: hidden;
                z-index: 1000;
                margin-bottom: 8px;
                box-shadow: -5px -10px 30px rgba(0,0,0,0.8);
            }

            .dropdown:hover .dropdown-content {
                display: block;
            }

            .dropdown-content a {
                color: #E2E2E9;
                padding: 10px 16px;
                text-decoration: none;
                display: block;
                font-size: 0.85rem;
            }

                .dropdown-content a:hover {
                    background: rgba(107, 91, 255, 0.1);
                    color: white;
                }

            /* ========================================================= */
            /* =================== RESPONSIVO ========================== */
            /* ========================================================= */

            /* Tablets (hasta 1024px) */
            @@media (max-width: 1024px) {
                .main-content {
                    padding: 50px 30px;
                }

                .contacts-grid {
                    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                }
                /* Ajusta mejor en tablet */
            }

            /* Teléfonos (hasta 768px) */
            @@media (max-width: 768px) {
                .navbar {
                    padding: 15px 20px;
                    flex-direction: column;
                    align-items: flex-start; /* Alinea a la izquierda para que el scroll se vea natural */
                    gap: 15px;
                }
                /* Pestañas Deslizables (Swipe) */
                .tab-row {
                    width: 100%;
                    flex-wrap: nowrap;
                    overflow-x: auto;
                    padding-bottom: 8px;
                    justify-content: flex-start;
                    -webkit-overflow-scrolling: touch;
                }

                    .tab-row::-webkit-scrollbar {
                        height: 4px;
                    }

                    .tab-row::-webkit-scrollbar-thumb {
                        background: rgba(255,255,255,0.15);
                        border-radius: 4px;
                    }

                .tab {
                    white-space: nowrap;
                    padding: 8px 16px;
                    font-size: 0.85rem;
                }

                .main-content {
                    padding: 30px 20px;
                }

                .page-title {
                    font-size: 2.2rem;
                }

                .page-subtitle {
                    font-size: 1rem;
                }
            }

            /* Celulares pequeños */
            @@media (max-width: 575.98px) {
                /* 1 sola columna perfecta */
                .contacts-grid {
                    grid-template-columns: 1fr;
                    gap: 15px;
                }

                .page-title {
                    font-size: 1.8rem;
                }

                .fav-card, .c-card {
                    padding: 15px;
                    gap: 12px;
                }

                .avatar-box {
                    width: 42px;
                    height: 42px;
                    font-size: 1.1rem;
                }

                .fav-name, .c-name {
                    font-size: 1rem;
                }

                .fav-detail, .c-phone {
                    font-size: 0.8rem;
                }
            }
    </style>
</head>
<body>

    <nav class="navbar">
        <a asp-controller="Contactos" asp-action="Index" class="nav-brand">
            <div class="brand-icon">📒</div>
            <span class="brand-name">Agenda Web</span>
        </a>
        <div class="tab-row">
            <a href="@Url.Action("Index", "Contactos")" class="tab"><span>👥</span> Contactos</a>
            <a href="@Url.Action("Index", "Categorias")" class="tab"><span>📁</span> Categorías</a>
            <a href="@Url.Action("Recientes", "Contactos")" class="tab active"><span>🕒</span> Recientes</a>
            <a href="@Url.Action("Ayuda", "Contactos")" class="tab"><span>❓</span> Ayuda</a>
        </div>
    </nav>

    <main class="main-content">
        <div class="header-section">
            <h1 class="page-title">Agregados Recientemente</h1>
            <p class="page-subtitle">
                Aquí encontrarás los últimos contactos que has integrado a tu agenda. Esta vista rápida está diseñada para ayudarte a retomar conversaciones recientes.
            </p>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center p-5" style="background: rgba(28, 28, 38, 0.4); border-radius: 24px; border: 1px dashed rgba(107, 91, 255, 0.3); text-align: center; padding: 50px;">
                <p style="color: #D1D1E0; font-size: 1.1rem;">Aún no has agregado contactos recientes.</p>
            </div>
        }
        else
        {
            <div class="contacts-grid">
                @{
                    int delay = 1;
                    int countFav = 0;
                    int countOtros = 0;
                    var favGradients = new[] { "linear-gradient(135deg, #6366f1, #a855f7)", "linear-gradient(135deg, #3b82f6, #2dd4bf)", "linear-gradient(135deg, #f43f5e, #fb923c)", "linear-gradient(135deg, #22c55e, #84cc16)", "linear-gradient(135deg, #8b5cf6, #d946ef)", "linear-gradient(135deg, #f59e0b, #eab308)" };
                    var neonPalette = new (string Bg, string Text)[] { ("rgba(99, 102, 241, 0.12)", "#818cf8"), ("rgba(16, 185, 129, 0.12)", "#34d399"), ("rgba(244, 63, 94, 0.12)", "#fb7185"), ("rgba(234, 179, 8, 0.12)", "#facc15"), ("rgba(168, 85, 247, 0.12)", "#c084fc"), ("rgba(6, 182, 212, 0.12)", "#22d3ee") };
                }

                @foreach (var contact in Model)
                {
                    if (contact.EsFavorito)
                    {
                        var grad = favGradients[countFav % 6]; countFav++;
                        <div class="fav-card" style="animation-delay: @(delay * 0.1)s;">
                            <div class="avatar-box" style="background: @grad; color: white;">
                                @(string.IsNullOrEmpty(contact.Nombre) ? "?" : contact.Nombre.Substring(0, 1).ToUpper())
                            </div>
                            <div style="flex:1;">
                                <div class="fav-name">@contact.Nombre @contact.Apellido</div>
                                <div class="fav-detail">@(contact.Telefonos.FirstOrDefault()?.Numero ?? "Sin teléfono")</div>
                            </div>
                            <span class="star-fav">★</span>
                            <div class="dropdown">
                                <button class="dropdown-btn">⋮</button>
                                <div class="dropdown-content">
                                    <a asp-action="Detalles" asp-route-id="@contact.Id">👀 Detalles</a>
                                    <a asp-action="Editar" asp-route-id="@contact.Id">✏️ Editar</a>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        var style = neonPalette[countOtros % 6]; countOtros++;
                        <div class="c-card" style="animation-delay: @(delay * 0.1)s;">
                            <div class="avatar-box" style="background-color: @style.Bg; border: 1.5px solid @style.Text; color: @style.Text;">
                                @(string.IsNullOrEmpty(contact.Nombre) ? "?" : contact.Nombre.Substring(0, 1).ToUpper())
                            </div>
                            <div style="flex:1;">
                                <div class="c-name">@contact.Nombre @contact.Apellido</div>
                                <div class="c-phone">@(contact.Telefonos.FirstOrDefault()?.Numero ?? "Sin teléfono")</div>
                            </div>
                            <div class="dropdown">
                                <button class="dropdown-btn">⋮</button>
                                <div class="dropdown-content">
                                    <a asp-action="Detalles" asp-route-id="@contact.Id">👀 Detalles</a>
                                    <a asp-action="Editar" asp-route-id="@contact.Id">✏️ Editar</a>
                                </div>
                            </div>
                        </div>
                    }
                    delay++;
                }
            </div>
        }
    </main>
</body>
</html>