@model ContactManagerWeb.Models.Contacto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eliminar Contacto</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
            :root {
                --bg-body: #0F0F14;
                --bg-card: #16161E;
                --danger: #FF4D4D;
                --danger-hover: #E63E3E;
                --cancel-bg: #2A2A35;
                --cancel-hover: #353542;
                --text-muted: #8A8A9E;
                --border: rgba(255, 255, 255, 0.05);
                --warning-color: #F59E0B;
                --warning-bg: rgba(245, 158, 11, 0.1);
            }

            body {
                background-color: var(--bg-body);
                color: #FFF;
                font-family: 'DM Sans', sans-serif;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                margin: 0;
                padding: 20px;
            }

            .card {
                background: var(--bg-card);
                padding: 40px 30px;
                border-radius: 20px;
                border: 1px solid var(--border);
                width: 100%;
                max-width: 400px;
                box-shadow: 0 20px 50px rgba(0,0,0,0.6);
                text-align: center;
            }

            .warning-icon {
                width: 60px;
                height: 60px;
                background: var(--warning-bg);
                color: var(--warning-color);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px auto;
                font-size: 1.8rem;
                border: 1px solid rgba(245, 158, 11, 0.2);
            }

            h2 {
                margin: 0 0 15px 0;
                font-weight: 700;
                font-size: 1.5rem;
                color: #FFF;
            }
        
            .warning-text {
                color: var(--text-muted);
                font-size: 0.95rem;
                line-height: 1.6;
                margin-bottom: 30px;
            }

            /* Contenedor de los botones lado a lado */
            .button-group {
                display: flex;
                gap: 15px;
                justify-content: center;
            }

            .btn {
                padding: 12px 24px;
                border-radius: 10px;
                font-family: 'DM Sans', sans-serif;
                font-weight: 700;
                font-size: 0.95rem;
                cursor: pointer;
                transition: all 0.3s ease;
                text-decoration: none;
                flex: 1; /* Hace que los botones midan lo mismo */
                border: none;
            }

            .btn-cancel {
                background: var(--cancel-bg);
                color: #FFF;
            }

                .btn-cancel:hover {
                    background: var(--cancel-hover);
                }

            .btn-danger {
                background: var(--danger);
                color: #FFF;
            }

                .btn-danger:hover {
                    background: var(--danger-hover);
                    transform: translateY(-2px);
                    box-shadow: 0 5px 15px rgba(255, 77, 77, 0.3);
                }
    </style>
</head>
<body>
    <div class="card">
        <div class="warning-icon">⚠️</div>
        
        <h2>¿Eliminar contacto?</h2>
        <p class="warning-text">Esta acción no se puede deshacer. El contacto será borrado permanentemente de tu agenda.</p>

        <form asp-action="Eliminar" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div class="button-group">
                <a asp-action="Index" class="btn btn-cancel">Cancelar</a>
                <button type="submit" class="btn btn-danger">Sí, eliminar</button>
            </div>
        </form>
    </div>
</body>
</html>