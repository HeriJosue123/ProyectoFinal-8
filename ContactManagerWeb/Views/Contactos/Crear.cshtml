@model ContactManagerWeb.Models.Contacto

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nuevo Contacto</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; }
        body { background-color: #121217; color: #FFFFFF; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
        
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .glass-card { background-color: #171721; border: 1px solid #2D2D3D; border-radius: 20px; padding: 40px; width: 100%; max-width: 550px; box-shadow: 0 20px 40px rgba(0,0,0,0.5); animation: fadeInUp 0.6s ease-out; }
        
        .form-header { text-align: center; margin-bottom: 30px; }
        .form-header h2 { font-family: 'DM Serif Display', serif; font-size: 2.2rem; font-weight: 400; margin-bottom: 5px; }
        .form-header p { color: #8A8A9E; font-size: 0.95rem; }

        .form-label { color: #8A8A9E; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 8px; margin-top: 15px; }
        .dark-input { width: 100%; background-color: #1C1C26; border: 1px solid #2D2D3D; color: #FFF; border-radius: 12px; padding: 12px 15px; transition: 0.3s; outline: none; }
        .dark-input:focus { background-color: #20202B; border-color: #5A4FCF; box-shadow: 0 0 0 3px rgba(90, 79, 207, 0.2); }
        
        .row-inputs { display: flex; gap: 15px; }
        .row-inputs > div { flex: 1; }

        .checkbox-container { display: flex; align-items: center; background-color: #1C1C26; border: 1px solid #2D2D3D; padding: 15px; border-radius: 12px; margin-top: 20px; margin-bottom: 30px; cursor: pointer; transition: 0.3s; }
        .checkbox-container:hover { border-color: #5A4FCF; }
        .checkbox-container input { width: 20px; height: 20px; margin-right: 15px; accent-color: #5A4FCF; cursor: pointer; }

        .btn-gradient { display: block; text-align: center; background: linear-gradient(135deg, #5A4FCF, #3E346B); color: white; border: none; padding: 15px; border-radius: 12px; font-weight: bold; width: 100%; font-size: 1rem; cursor: pointer; transition: 0.3s; text-decoration: none; margin-bottom: 15px; }
        .btn-gradient:hover { background: linear-gradient(135deg, #6B5BFF, #4B3F85); transform: translateY(-3px); box-shadow: 0 10px 20px rgba(90, 79, 207, 0.3); }
        
        .btn-cancel { display: block; text-align: center; color: #8A8A9E; text-decoration: none; font-size: 0.9rem; font-weight: 600; transition: 0.3s; }
        .btn-cancel:hover { color: #FFF; }
    </style>
</head>
<body>

    <div class="glass-card">
        <div class="form-header">
            <h2>Nuevo Contacto</h2>
            <p>Añade los detalles a tu agenda</p>
        </div>

        <form asp-action="Crear">
            <label class="form-label">Nombre Completo</label>
            <input asp-for="Nombre" class="dark-input" required placeholder="Ej: Laura Pérez" />

            <div class="row-inputs">
                <div>
                    <label class="form-label">Teléfono</label>
                    <input asp-for="Telefono" class="dark-input" placeholder="+503 ..." />
                </div>
                <div>
                    <label class="form-label">Categoría</label>
                    <select asp-for="Categoria" class="dark-input">
                        <option value="Trabajo">💼 Trabajo</option>
                        <option value="Amigos">👥 Amigos</option>
                        <option value="Familia">❤️ Familia</option>
                    </sel