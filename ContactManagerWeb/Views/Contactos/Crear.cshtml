@model ContactManagerWeb.Models.Contacto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nuevo Contacto — Contact Manager Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: #171721;
            --bg-input: #1C1C26;
            --accent: #5A4FCF;
            --text-muted: #8A8A9E;
            --border: #2D2D3D;
            --danger: #FF5555;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'DM Sans', sans-serif;
        }

        body {
            background-color: var(--bg-body);
            color: #FFFFFF;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .glass-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 550px;
        }

        .form-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .form-header h2 {
                font-family: 'DM Serif Display', serif;
                font-size: 2.2rem;
            }

        .form-label {
            color: var(--text-muted);
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            display: block;
            margin-bottom: 8px;
            margin-top: 15px;
        }

        .dark-input {
            width: 100%;
            background-color: var(--bg-input);
            border: 1px solid var(--border);
            color: #FFF;
            border-radius: 12px;
            padding: 12px 15px;
            outline: none;
        }

            .dark-input:focus {
                border-color: var(--accent);
            }

        /* ESTILO PARA LAS ADVERTENCIAS DEBAJO DE LOS BOXES */
        .text-danger {
            color: var(--danger);
            font-size: 0.75rem;
            font-weight: 500;
            margin-top: 6px;
            display: block;
            padding-left: 5px;
        }

        .row-inputs {
            display: flex;
            gap: 15px;
        }

            .row-inputs > div {
                flex: 1;
            }

        .btn-gradient {
            display: block;
            text-align: center;
            background: linear-gradient(135deg, var(--accent), #3E346B);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 12px;
            font-weight: bold;
            width: 100%;
            cursor: pointer;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="glass-card">
        <div class="form-header">
            <h2>Nuevo Contacto</h2>
            <p>Añade los detalles a tu agenda</p>
        </div>

        <form asp-action="Crear" method="post">
            <div class="row-inputs">
                <div>
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="dark-input" placeholder="Ej: Laura" />
                    <span asp-validation-for="Nombre" class="text-danger"></span> @* <-- APARECE AQUÍ *@
                </div>
                <div>
                    <label class="form-label">Apellido (Opcional)</label>
                    <input asp-for="Apellido" class="dark-input" placeholder="Ej: Pérez" />
                </div>
            </div>

            <div class="row-inputs">
                <div>
                    <label class="form-label">Teléfono</label>
                    <input asp-for="Telefono" id="Telefono" class="dark-input" placeholder="+503 XXXX-XXXX" />
                    <span asp-validation-for="Telefono" class="text-danger"></span> @* <-- APARECE AQUÍ *@
                </div>
                <div>
                    <label class="form-label">Categoría</label>
                    <select asp-for="Categoria" class="dark-input">
                        <option value="">-- Seleccionar --</option>
                        @if (ViewBag.Categorias != null)
                        {
                            foreach (var cat in (IEnumerable<ContactManagerWeb.Models.Categoria>)ViewBag.Categorias)
                            {
                                <option value="@cat.NombreCategoria">@cat.Emoji @cat.NombreCategoria</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="Categoria" class="text-danger"></span>
                </div>
            </div>

            <label class="form-label">Correo Electrónico (Opcional)</label>
            <input asp-for="Correo" class="dark-input" type="email" placeholder="correo@ejemplo.com" />
            <span asp-validation-for="Correo" class="text-danger"></span> @* <-- APARECE AQUÍ *@

            <label class="form-label">Dirección (Opcional)</label>
            <input asp-for="Direccion" class="dark-input" placeholder="Ingresa la dirección" />

            <button type="submit" class="btn-gradient">Guardar Contacto</button>
            <a asp-action="Index" style="display:block; text-align:center; color:var(--text-muted); margin-top:15px; text-decoration:none;">Cancelar</a>
        </form>
    </div>

    <script>
        // Mantenemos la lógica de la máscara de teléfono que ya tenían
        const phoneInput = document.getElementById('Telefono');
        phoneInput.addEventListener('input', function(e) {
            let value = this.value.replace(/\D/g, '');
            if (value.startsWith('503')) value = value.substring(3);
            value = value.substring(0, 8);
            if (value.length === 0) this.value = '';
            else if (value.length <= 4) this.value = '+503 ' + value;
            else this.value = '+503 ' + value.substring(0, 4) + '-' + value.substring(4);
        });
    </script>
</body>
</html>