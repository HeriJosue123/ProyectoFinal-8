    @* SCRIPTS *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // --- EMOJI PICKER LÓGICA (Simplificada) ---
        const emojiBtn = document.getElementById('emojiBtn');
        const emojiPopover = document.getElementById('emojiPopover');
        const inputEmojiOculto = document.getElementById('inputEmojiOculto');

        // Abrir/Cerrar popover
        emojiBtn.addEventListener('click', function(e) {
            e.preventDefault();
            emojiPopover.classList.toggle('show');
        });

        // Función llamada por cada emoji (ver HTML)
        function selectEmoji(emoji) {
            emojiBtn.textContent = emoji;
            inputEmojiOculto.value = emoji;
            emojiPopover.classList.remove('show'); 
        }

        // Cerrar popover si se hace clic fuera
        document.addEventListener('click', function(e) {
            if (!emojiBtn.contains(e.target) && !emojiPopover.contains(e.target)) {
                emojiPopover.classList.remove('show');
            }
        });

        // --- FAVORITOS TEXTO ANIMADO ---
        const favCheckbox = document.getElementById('favCheck');
        const favLabelText = document.getElementById('favLabelText');

        favCheckbox.addEventListener('change', function() {
            if (this.checked) {
                favLabelText.textContent = '¡Es un contacto favorito! ⭐';
            } else {
                favLabelText.textContent = 'Marcar como favorito ⭐';
            }
        });
        favCheckbox.dispatchEvent(new Event('change'));

        // --- MOSTRAR/OCULTAR CATEGORÍA NUEVA ---
        function verificarNuevaCategoria() {
            var select = document.getElementById("selectCategoria");
            var container = document.getElementById("nuevaCategoriaContainer");
            var inputTexto = document.getElementById("inputNuevaCategoria");
            
            if (select.value === "NUEVA_CATEGORIA") {
                container.style.display = "block";
                inputTexto.focus();
            } else {
                container.style.display = "none";
                inputTexto.value = "";
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            verificarNuevaCategoria();
        });

        // --- MÁSCARA DE TELÉFONO OBLIGATORIA ---
        const phoneInput = document.getElementById('Telefono');
        phoneInput.addEventListener('focus', function() {
            if (this.value.trim() === "") { this.value = "+503 "; }
        });
        phoneInput.addEventListener('input', function(e) {
            let value = this.value;
            if (!value.startsWith("+503 ")) {
                let digitsOnly = value.replace(/\D/g, "");
                if (digitsOnly.startsWith("503")) { digitsOnly = digitsOnly.substring(3); }
                value = "+503 " + digitsOnly;
            }
            let numbers = value.substring(5).replace(/\D/g, ""); 
            numbers = numbers.substring(0, 8);
            if (numbers.length > 4) {
                this.value = "+503 " + numbers.substring(0, 4) + "-" + numbers.substring(4);
            } else {
                this.value = "+503 " + numbers;
            }
        });
        phoneInput.addEventListener('keydown', function(e) {
            if (e.key === "Backspace" && this.value.length <= 5) {
                e.preventDefault();
            }
        });
    </script>
