@model ContactManagerWeb.Models.Contacto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar — @Model.Nombre</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: #171721;
            --bg-input: #1C1C26;
            --accent: #5A4FCF;
            --text-muted: #8A8A9E;
            --border: #2D2D3D;
            --star-off: #444;
            --star-on: #FBBF24;
            --danger: #FF5555;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; }
        
        body {
            background-color: var(--bg-body);
            color: #FFFFFF;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 15px;
        }

        .glass-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 30px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            animation: fadeIn 0.4s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .form-header { text-align: center; margin-bottom: 25px; }
        .form-header h2 { font-family: 'DM Serif Display', serif; font-size: 2rem; margin-bottom: 5px; }
        .form-header p { color: var(--text-muted); font-size: 0.85rem; }

        .form-label {
            color: var(--text-muted);
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: block;
            margin-bottom: 8px;
            margin-top: 15px;
        }

        .dark-input {
            width: 100%;
            background-color: var(--bg-input);
            border: 1px solid var(--border);
            color: #FFF;
            border-radius: 10px;
            padding: 10px 14px;
            transition: 0.3s;
            outline: none;
            font-size: 0.9rem;
        }

        .dark-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(90, 79, 207, 0.2);
        }

        .row-inputs { display: flex; gap: 15px; }
        .row-inputs > div { flex: 1; }

        /* --- ESTILOS DE LA ESTRELLA --- */
        .star-toggle-container {
            display: flex;
            align-items: center;
            background-color: var(--bg-input);
            border: 1px solid var(--border);
            padding: 12px 18px;
            border-radius: 12px;
            margin-top: 20px;
            margin-bottom: 25px;
            cursor: pointer;
            transition: 0.3s;
        }
        .star-toggle-container:hover { border-color: var(--accent); }

        .hidden-check { display: none; }
        .star-icon-label {
            font-size: 2.2rem;
            cursor: pointer;
            color: var(--star-off);
            transition: all 0.3s ease;
            line-height: 1;
            margin-right: 12px;
            user-select: none;
        }

        .hidden-check:checked + .star-icon-label {
            color: var(--star-on);
            text-shadow: 0 0 15px rgba(251, 191, 36, 0.4);
            transform: scale(1.1);
        }

        #favText { font-weight: 600; font-size: 0.85rem; }

        .btn-save {
            background: var(--accent);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            width: 100%;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-bottom: 15px;
        }
        .btn-save:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
            box-shadow: 0 10px 20px rgba(90, 79, 207, 0.3);
        }

        .btn-cancel {
            display: block;
            text-align: center;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .text-danger { color: var(--danger); font-size: 0.7rem; margin-top: 4px; display: block; }
    </style>
</head>
<body>

    <div class="glass-card">
        <div class="form-header">
            <h2>Editar Contacto</h2>
            <p>Modifica los datos de <strong>@Model.Nombre</strong></p>
        </div>

        <form asp-action="Editar" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FechaCreacion" />

            <div class="row-inputs">
                <div>
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="dark-input" autocomplete="off" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Apellido</label>
                    <input asp-for="Apellido" class="dark-input" autocomplete="off" />
                </div>
            </div>

            <div class="row-inputs">
                <div>
                    <label class="form-label">Teléfono</label>
                    <input asp-for="Telefono" id="Telefono" class="dark-input" autocomplete="off" />
                    <span asp-validation-for="Telefono" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Categoría</label>
                    <select asp-for="Categoria" class="dark-input">
                        @if (ViewBag.Categorias != null)
                        {
                            foreach (var cat in (IEnumerable<ContactManagerWeb.Models.Categoria>)ViewBag.Categorias)
                            {
                                <option value="@cat.NombreCategoria">@cat.Emoji @cat.NombreCategoria</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <label class="form-label">Correo Electrónico (Opcional)</label>
            <input asp-for="Correo" class="dark-input" type="email" autocomplete="off" />
            <span asp-validation-for="Correo" class="text-danger"></span>

            <label class="form-label">Dirección (Opcional)</label>
            <input asp-for="Direccion" class="dark-input" autocomplete="off" />

            <label class="form-label">Importancia</label>
            <div class="star-toggle-container" onclick="document.getElementById('favStar').click();">
                <input type="checkbox" asp-for="EsFavorito" id="favStar" class="hidden-check" />
                <label for="favStar" class="star-icon-label" onclick="event.stopPropagation();">★</label>
                <span id="favText" style="color: @(Model.EsFavorito ? "#FBBF24" : "#8A8A9E");">
                    @(Model.EsFavorito ? "¡Es un contacto favorito! ⭐" : "Marcar como favorito")
                </span>
            </div>

            <button type="submit" class="btn-save">Guardar Cambios</button>
            <a asp-action="Index" class="btn-cancel">Cancelar y volver</a>
        </form>
    </div>

    <script>
        // --- LÓGICA DE LA ESTRELLA ---
        const checkbox = document.getElementById('favStar');
        const text = document.getElementById('favText');

        checkbox.addEventListener('change', function() {
            if (this.checked) {
                text.innerText = "¡Es un contacto favorito! ⭐";
                text.style.color = "#FBBF24";
            } else {
                text.innerText = "Marcar como favorito";
                text.style.color = "#8A8A9E";
            }
        });

        // --- MÁSCARA DE TELÉFONO OBLIGATORIA (+503, Sin Letras, Guion Automático) ---
        const phoneInput = document.getElementById('Telefono');

        if (phoneInput) {
            // 1. Al entrar al campo, poner el prefijo si está vacío
            phoneInput.addEventListener('focus', function() {
                if (this.value.trim() === "") {
                    this.value = "+503 ";
                }
            });

            // 2. Controlar la escritura (Borra letras, limita números, pone guion)
            phoneInput.addEventListener('input', function(e) {
                let value = this.value;

                // Forzar que siempre empiece con +503 
                if (!value.startsWith("+503 ")) {
                    let digitsOnly = value.replace(/\D/g, "");
                    if (digitsOnly.startsWith("503")) {
                        digitsOnly = digitsOnly.substring(3);
                    }
                    value = "+503 " + digitsOnly;
                }

                // Extraer solo los números después del prefijo
                let numbers = value.substring(5).replace(/\D/g, ""); 

                // Limitar a 8 dígitos reales
                numbers = numbers.substring(0, 8);

                // Aplicar formato final: +503 XXXX-XXXX
                if (numbers.length > 4) {
                    this.value = "+503 " + numbers.substring(0, 4) + "-" + numbers.substring(4);
                } else {
                    this.value = "+503 " + numbers;
                }
            });

            // 3. Bloquear que borren el prefijo con el teclado (Backspace)
            phoneInput.addEventListener('keydown', function(e) {
                if (e.key === "Backspace" && this.value.length <= 5) {
                    e.preventDefault();
                }
            });
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>