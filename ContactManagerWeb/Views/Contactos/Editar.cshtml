@model ContactManagerWeb.Models.Contacto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar — @Model.Nombre</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: #171721;
            --bg-input: #1C1C26;
            --accent: #5A4FCF;
            --text-muted: #8A8A9E;
            --border: #2D2D3D;
            --danger: #FF5555;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; }
        body { background-color: var(--bg-body); color: #FFFFFF; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
        
        .glass-card { background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 30px; width: 100%; max-width: 500px; box-shadow: 0 20px 40px rgba(0,0,0,0.5); transition: max-width 0.3s ease; animation: fadeIn 0.4s ease-out; }
        
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .form-header { text-align: center; margin-bottom: 25px; }
        .form-header h2 { font-family: 'DM Serif Display', serif; font-size: 1.8rem; margin-bottom: 3px; }
        .form-header p { color: var(--text-muted); font-size: 0.9rem; }
        
        .form-label { color: var(--text-muted); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; display: block; margin-bottom: 6px; margin-top: 8px; }
        .dark-input { width: 100%; background-color: var(--bg-input); border: 1px solid var(--border); color: #FFF; border-radius: 10px; padding: 10px 12px; outline: none; transition: 0.3s; font-size: 0.9rem; }
        .dark-input:focus { border-color: var(--accent); box-shadow: 0 0 0 4px rgba(90, 79, 207, 0.1); }
        .text-danger { color: var(--danger); font-size: 0.7rem; font-weight: 500; margin-top: 4px; display: block; padding-left: 3px; }
        
        .btn-gradient { display: block; text-align: center; background: linear-gradient(135deg, var(--accent), #3E346B); color: white; border: none; padding: 12px; border-radius: 10px; font-weight: bold; width: 100%; cursor: pointer; margin-top: 18px; transition: 0.3s; font-size: 0.95rem; }
        .btn-gradient:hover { transform: translateY(-1px); filter: brightness(1.1); box-shadow: 0 8px 16px rgba(90, 79, 207, 0.25); }
        
        .validation-summary-errors { background: rgba(255, 85, 85, 0.1); color: var(--danger); padding: 12px; border-radius: 10px; margin-bottom: 18px; font-size: 0.8rem; }
        .validation-summary-errors ul { list-style: none; margin: 0; padding: 0; }

        /* --- FAVORITOS --- */
        .fav-checkbox-hidden { display: none; }
        .fav-box {
            display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.02); border: 1px dashed var(--border);
            border-radius: 10px; padding: 10px; cursor: pointer; transition: all 0.3s ease; margin-top: 12px; margin-bottom: 4px; width: 100%;
        }
        .fav-box:hover { background: rgba(255,255,255,0.04); border-color: #4A4A63; }
        .fav-star { font-size: 1.5rem; color: #3E3E54; transition: all 0.3s ease; line-height: 1; margin-top: -3px; }
        .fav-text { color: var(--text-muted); font-weight: 600; font-size: 0.85rem; transition: all 0.3s ease; }
        
        .fav-checkbox-hidden:checked + .fav-box { border-style: solid; border-color: rgba(251, 191, 36, 0.3); background: rgba(251, 191, 36, 0.05); }
        .fav-checkbox-hidden:checked + .fav-box .fav-star { color: #FBBF24; text-shadow: 0 0 10px rgba(251, 191, 36, 0.5); transform: scale(1.05); }
        .fav-checkbox-hidden:checked + .fav-box .fav-text { color: #FBBF24; }

        /* --- EMOJI PICKER PREMIUM CON SCROLL Y GRUPOS --- */
        .emoji-picker-wrapper { position: relative; }
        .emoji-btn {
            background-color: var(--bg-input); border: 1px solid var(--border); color: #FFF;
            border-radius: 10px; padding: 10px; width: 50px; height: 100%; cursor: pointer;
            font-size: 1.3rem; display: flex; align-items: center; justify-content: center; transition: 0.3s;
        }
        .emoji-btn:hover { border-color: var(--accent); background: rgba(90, 79, 207, 0.1); }
        
        .emoji-popover {
            position: absolute; top: 110%; left: 0; background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 12px; padding: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.8); z-index: 100;
            display: none; width: 280px; 
        }
        .emoji-popover.show { display: block; animation: popUp 0.2s ease-out forwards; }
        
        .emoji-scroll-area { max-height: 220px; overflow-y: auto; overflow-x: hidden; padding-right: 5px; }
        .emoji-scroll-area::-webkit-scrollbar { width: 4px; }
        .emoji-scroll-area::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
        .emoji-scroll-area::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        .emoji-section-title { font-size: 0.65rem; color: #A396FF; font-weight: 700; text-transform: uppercase; margin: 12px 0 6px 5px; letter-spacing: 0.5px; }
        .emoji-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 4px; }
        .emoji-item { text-align: center; padding: 6px 0; font-size: 1.2rem; cursor: pointer; border-radius: 8px; transition: 0.2s; line-height: 1; }
        .emoji-item:hover { background: rgba(90, 79, 207, 0.2); transform: scale(1.2); }

        @@keyframes popUp {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Ajustes Responsivos Móviles */
        @@media (max-width: 576px) {
            .glass-card { padding: 20px 15px; max-width: 100%; border-radius: 15px; }
            .form-header h2 { font-size: 1.6rem; }
            .emoji-popover { width: 250px; }
        }
    </style>
</head>
