    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script>
        const emojiBtn=document.getElementById('emojiBtn'),emojiPopover=document.getElementById('emojiPopover'),inputEmojiOculto=document.getElementById('inputEmojiOculto');
        emojiBtn.addEventListener('click',e=>{e.preventDefault();emojiPopover.classList.toggle('show');});
        function selectEmoji(e){emojiBtn.textContent=e;inputEmojiOculto.value=e;emojiPopover.classList.remove('show');}
        document.addEventListener('click',e=>{if(!emojiBtn.contains(e.target)&&!emojiPopover.contains(e.target))emojiPopover.classList.remove('show');});
        
        const f = document.getElementById('favCheck');
        f.addEventListener('change',function(){document.getElementById('favLabelText').textContent=this.checked?'¡Es un contacto favorito! ⭐':'Marcar como favorito ⭐';});
        f.dispatchEvent(new Event('change'));

        function verificarNuevaCategoria(){
            const s=document.getElementById("selectCategoria"), c=document.getElementById("nuevaCategoriaContainer"), i=document.getElementById("inputNuevaCategoria");
            if(s.value==="NUEVA_CATEGORIA"){ c.style.display="block"; i.focus(); } else { c.style.display="none"; i.value=""; }
        }
        document.addEventListener("DOMContentLoaded", verificarNuevaCategoria);

        function aplicarMascara(id){
            const i=document.getElementById(id);
            if(!i) return;
            i.addEventListener('focus',function(){if(this.value.trim()==="")this.value="+503 ";});
            i.addEventListener('input',function(){
                let v=this.value;if(!v.startsWith("+503 ")){let d=v.replace(/\D/g,"");if(d.startsWith("503"))d=d.substring(3);v="+503 "+d;}
                let n=v.substring(5).replace(/\D/g,"").substring(0,8);this.value=n.length>4?"+503 "+n.substring(0,4)+"-"+n.substring(4):"+503 "+n;
            });
        }
        aplicarMascara('Telefono');aplicarMascara('TelefonoSecundario');
    </script>
