@model ContactManagerWeb.Models.Contacto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar — @Model.Nombre</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: #171721;
            --bg-input: #1C1C26;
            --accent: #5A4FCF;
            --text-muted: #8A8A9E;
            --border: #2D2D3D;
            --star-off: #444;
            --star-on: #FBBF24;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'DM Sans', sans-serif;
        }

        body {
            background-color: var(--bg-body);
            color: #FFFFFF;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 15px;
        }

        .glass-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 30px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            animation: fadeIn 0.4s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .form-header {
            text-align: center;
            margin-bottom: 25px;
        }

            .form-header h2 {
                font-family: 'DM Serif Display', serif;
                font-size: 2rem;
                margin-bottom: 5px;
            }

            .form-header p {
                color: var(--text-muted);
                font-size: 0.85rem;
            }

        .form-label {
            color: var(--text-muted);
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: block;
            margin-bottom: 8px;
            margin-top: 15px;
        }

        .dark-input {
            width: 100%;
            background-color: var(--bg-input);
            border: 1px solid var(--border);
            color: #FFF;
            border-radius: 10px;
            padding: 10px 14px;
            transition: 0.3s;
            outline: none;
            font-size: 0.9rem;
        }

            .dark-input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(90, 79, 207, 0.2);
            }

        .row-inputs {
            display: flex;
            gap: 15px;
        }

            .row-inputs > div {
                flex: 1;
            }

        /* --- ESTILOS DE LA ESTRELLA INTERACTIVA --- */
        .star-toggle-container {
            display: flex;
            align-items: center;
            background-color: var(--bg-input);
            border: 1px solid var(--border);
            padding: 12px 18px;
            border-radius: 12px;
            margin-top: 20px;
            margin-bottom: 25px;
            cursor: pointer;
            transition: 0.3s;
        }

            .star-toggle-container:hover {
                border-color: var(--accent);
            }

        .hidden-check {
            display: none;
        }

        .star-icon-label {
            font-size: 2.2rem;
            cursor: pointer;
            color: var(--star-off);
            transition: all 0.3s ease;
            line-height: 1;
            margin-right: 12px;
            user-select: none;
        }

        .hidden-check:checked + .star-icon-label {
            color: var(--star-on);
            text-shadow: 0 0 15px rgba(251, 191, 36, 0.4);
            transform: scale(1.1);
        }

        #favText {
            font-weight: 600;
            font-size: 0.85rem;
            transition: 0.3s;
        }
        /* ------------------------------------------ */

        .btn-save {
            background: var(--accent);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            width: 100%;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-bottom: 15px;
        }

            .btn-save:hover {
                transform: translateY(-2px);
                filter: brightness(1.1);
                box-shadow: 0 10px 20px rgba(90, 79, 207, 0.3);
            }

        .btn-cancel {
            display: block;
            text-align: center;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
        }

            .btn-cancel:hover {
                color: #FFF;
            }

        .text-danger {
            color: #FF5555;
            font-size: 0.7rem;
            margin-top: 4px;
            display: block;
        }
    </style>
</head>
<body>

    <div class="glass-card">
        <div class="form-header">
            <h2>Editar Contacto</h2>
            <p>Modifica los datos de <strong>@Model.Nombre</strong></p>
        </div>

        <form asp-action="Editar" method="post">
            @* Campos ocultos para mantener la integridad de la BD *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FechaCreacion" />

            <div class="row-inputs">
                <div>
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="dark-input" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Apellido</label>
                    <input asp-for="Apellido" class="dark-input" />
                    <span asp-validation-for="Apellido" class="text-danger"></span>
                </div>
            </div>

            <div class="row-inputs">
                <div>
                    <label class="form-label">Teléfono</label>
                    <input asp-for="Telefono" class="dark-input" />
                    <span asp-validation-for="Telefono" class="text-danger"></span>
                </div>
                <div>
                    <label class="form-label">Categoría</label>
                    <select asp-for="Categoria" class="dark-input">
                        <option value="Trabajo">💼 Trabajo</option>
                        <option value="Amigos">👥 Amigos</option>
                        <option value="Familia">❤️ Familia</option>
                        <option value="General">📁 General</option>
                    </select>
                </div>
            </div>

            <label class="form-label">Correo Electrónico</label>
            <input asp-for="Correo" class="dark-input" type="email" />

            <label class="form-label">Dirección</label>
            <input asp-for="Direccion" class="dark-input" />

            <label class="form-label">Importancia</label>
            <div class="star-toggle-container" onclick="document.getElementById('favStar').click();">
                <input type="checkbox" asp-for="EsFavorito" id="favStar" class="hidden-check" />
                <label for="favStar" class="star-icon-label" onclick="event.stopPropagation();">★</label>
                <span id="favText" style="color: @(Model.EsFavorito ? "#FBBF24" : "#8A8A9E");">
                    @(Model.EsFavorito ? "¡Es un contacto favorito! ⭐" : "Marcar como favorito")
                </span>
            </div>

            <button type="submit" class="btn-save">Guardar Cambios</button>
            <a asp-action="Index" class="btn-cancel">Cancelar</a>
        </form>
    </div>

    <script>
        // Lógica para que el texto cambie al presionar la estrella
        const checkbox = document.getElementById('favStar');
        const text = document.getElementById('favText');

        checkbox.addEventListener('change', function() {
            if (this.checked) {
                text.innerText = "¡Es un contacto favorito! ⭐";
                text.style.color = "#FBBF24";
            } else {
                text.innerText = "Marcar como favorito";
                text.style.color = "#8A8A9E";
            }
        });
    </script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>