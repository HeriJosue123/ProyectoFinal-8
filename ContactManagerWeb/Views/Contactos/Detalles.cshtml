@model ContactManagerWeb.Models.Contacto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Detalles — @Model.Nombre</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: #171721;
            --bg-accent: #1C1C26;
            --accent: #5A4FCF;
            --text-muted: #8A8A9E;
            --border: #2D2D3D;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'DM Sans', sans-serif;
        }

        body {
            background-color: var(--bg-body);
            color: #FFFFFF;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 15px;
        }

        .glass-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 25px;
            width: 100%;
            max-width: 400px; /* Más estrecha */
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
            position: relative;
        }

        .avatar-small {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #5A4FCF, #9D88FF);
            border-radius: 15px;
            margin: 0 auto 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 700;
        }

        .header h2 {
            font-family: 'DM Serif Display', serif;
            font-size: 1.8rem;
            margin-bottom: 2px;
        }

        .header .cat {
            color: var(--accent);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 1.5px;
        }

        .info-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 25px;
        }

        .info-box {
            background: var(--bg-accent);
            padding: 12px 16px;
            border-radius: 12px;
            border: 1px solid var(--border);
            display: flex;
            flex-direction: column;
        }

        .label {
            color: var(--text-muted);
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 2px;
        }

        .value {
            font-size: 0.95rem;
            font-weight: 500;
            color: #DDD;
        }

        .actions {
            display: flex;
            gap: 10px;
        }

        .btn {
            flex: 1;
            padding: 12px;
            border-radius: 10px;
            text-align: center;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.85rem;
            transition: 0.2s;
        }

        .btn-edit {
            background: var(--accent);
            color: white;
            border: none;
        }

            .btn-edit:hover {
                background: #6B5BFF;
                transform: translateY(-2px);
            }

        .btn-back {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
        }

            .btn-back:hover {
                color: white;
                border-color: white;
            }

        .fav-star {
            position: absolute;
            top: 0;
            right: 0;
            font-size: 1.2rem;
            color: #FBBF24;
        }
    </style>
</head>
<body>

    <div class="glass-card">
        <div class="header">
            @if (Model.EsFavorito)
            {
                <span class="fav-star">⭐</span>
            }
            <div class="avatar-small">
                @(Model.Nombre.Length >= 1 ? Model.Nombre.Substring(0, 1).ToUpper() : "?")
            </div>
            <h2>@Model.Nombre @Model.Apellido</h2>
            <span class="cat">@Model.Categoria</span>
        </div>

        <div class="info-list">
            <div class="info-box">
                <span class="label">Teléfono</span>
                <span class="value">@Model.Telefono</span>
            </div>

            <div class="info-box">
                <span class="label">Email</span>
                <span class="value">@(string.IsNullOrEmpty(Model.Correo) ? "—" : Model.Correo)</span>
            </div>

            <div class="info-box">
                <span class="label">Dirección</span>
                <span class="value">@(string.IsNullOrEmpty(Model.Direccion) ? "No registrada" : Model.Direccion)</span>
            </div>
        </div>

        <div class="actions">
            <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-edit">Editar</a>
            <a asp-action="Index" class="btn btn-back">Volver</a>
        </div>

        <p style="text-align: center; font-size: 0.65rem; color: var(--text-muted); margin-top: 15px;">
            Registrado el @Model.FechaCreacion.ToString("dd/MM/yyyy")
        </p>
    </div>

</body>
</html>