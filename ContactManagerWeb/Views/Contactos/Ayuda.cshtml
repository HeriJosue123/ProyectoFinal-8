@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Centro de Ayuda";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Centro de Ayuda — Agenda Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
            :root {
                --bg-main: #0B0B10;
                --bg-card: rgba(28, 28, 38, 0.5);
                --text-white: #FFFFFF;
                --text-muted: #8A8A9E;
                --border-color: rgba(255, 255, 255, 0.08);
                --accent: #6B5BFF;
                --accent-glow: rgba(107, 91, 255, 0.35);
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
                font-family: 'DM Sans', sans-serif;
            }

            body {
                background-color: var(--bg-main);
                color: var(--text-white);
                height: 100vh;
                display: flex;
                flex-direction: column;
                overflow-x: hidden;
                overflow-y: auto;
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .navbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px 50px;
                background: rgba(15, 15, 20, 0.8);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border-bottom: 1px solid var(--border-color);
                position: sticky;
                top: 0;
                z-index: 100;
                animation: fadeUp 0.6s ease-out forwards;
            }

            .nav-brand {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
                color: var(--text-white);
            }

            .brand-icon {
                background: linear-gradient(135deg, #9D88FF, #6B5BFF);
                width: 32px;
                height: 32px;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                box-shadow: 0 4px 12px var(--accent-glow);
            }

            .brand-name {
                font-weight: 800;
                font-size: 1.25rem;
                letter-spacing: 0.5px;
                background: linear-gradient(135deg, #FFFFFF, #BDB2FF);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .tab-row {
                display: flex;
                gap: 6px;
                background: rgba(0, 0, 0, 0.4);
                padding: 6px;
                border-radius: 16px;
                border: 1px solid rgba(255, 255, 255, 0.05);
                box-shadow: inset 0 4px 10px rgba(0,0,0,0.5);
                flex-wrap: wrap;
                align-items: center;
            }

            .tab {
                color: #8A8A9E;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.9rem;
                padding: 10px 18px;
                border-radius: 12px;
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .tab:hover {
                    color: white;
                    background: rgba(255,255,255,0.03);
                    transform: translateY(-2px);
                }

                .tab.active {
                    background: linear-gradient(135deg, var(--accent), #8375FF);
                    color: white;
                    box-shadow: 0 6px 20px rgba(107, 91, 255, 0.4);
                    transform: translateY(-2px);
                }

            /* --- CONTENIDO PRINCIPAL --- */
            .main-content {
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                padding: 60px 40px;
                position: relative;
                z-index: 1;
                width: 100%;
            }

            .ambient-glow {
                position: absolute;
                top: -10%;
                left: 50%;
                transform: translateX(-50%);
                width: 800px;
                height: 500px;
                background: radial-gradient(ellipse at top, rgba(107, 91, 255, 0.1), transparent 60%);
                pointer-events: none;
                z-index: -1;
            }

            .hero-section {
                text-align: center;
                max-width: 800px;
                margin-bottom: 50px;
                animation: fadeUp 0.6s ease-out forwards;
            }

            .hero-title {
                font-size: 3rem;
                font-weight: 800;
                letter-spacing: -1px;
                margin-bottom: 15px;
                color: var(--text-white);
            }

            .hero-subtitle {
                font-size: 1.1rem;
                color: #D1D1E0;
                line-height: 1.6;
            }

            .help-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 20px;
                width: 100%;
                max-width: 1300px;
            }

            .help-card {
                background: var(--bg-card);
                border: 1px solid var(--border-color);
                border-radius: 20px;
                padding: 30px 25px;
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                opacity: 0;
                position: relative;
                overflow: hidden;
                animation: fadeUp 0.6s ease-out forwards;
                backdrop-filter: blur(10px);
            }

                .help-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 4px;
                    background: var(--color);
                    opacity: 0.4;
                    transition: 0.4s;
                }

                .help-card:nth-child(1) {
                    --color: #3b82f6;
                    animation-delay: 0.1s;
                }

                .help-card:nth-child(2) {
                    --color: #f59e0b;
                    animation-delay: 0.2s;
                }

                .help-card:nth-child(3) {
                    --color: #8b5cf6;
                    animation-delay: 0.3s;
                }

                .help-card:nth-child(4) {
                    --color: #ec4899;
                    animation-delay: 0.4s;
                }

                .help-card:hover {
                    transform: translateY(-10px);
                    border-color: var(--color);
                    background: rgba(28, 28, 38, 0.8);
                    box-shadow: 0 15px 35px rgba(0,0,0,0.4);
                }

                    .help-card:hover::before {
                        opacity: 1;
                        box-shadow: 0 0 15px var(--color);
                    }

            .icon-box {
                width: 54px;
                height: 54px;
                border-radius: 16px;
                background: rgba(255,255,255,0.03);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.6rem;
                margin-bottom: 20px;
                transition: 0.4s;
            }

            .help-card:hover .icon-box {
                transform: scale(1.1) rotate(10deg);
                background: var(--color);
                color: white;
            }

            .help-card h3 {
                font-size: 1.2rem;
                font-weight: 800;
                color: #FFFFFF;
                margin-bottom: 12px;
            }

            .help-card p {
                font-size: 0.9rem;
                color: var(--text-muted);
                line-height: 1.6;
            }

            /*  RESPONSIVO  */

            @@media (max-width: 1024px) {
                .help-grid {
                    grid-template-columns: repeat(2, 1fr);
                }

                .main-content {
                    padding: 50px 30px;
                    justify-content: flex-start;
                }
            }

            @@media (max-width: 768px) {
                .navbar {
                    padding: 15px 20px;
                    flex-direction: column;
                    align-items: flex-start; 
                    gap: 15px;
                }

                .tab-row {
                    width: 100%;
                    flex-wrap: nowrap;
                    overflow-x: auto;
                    padding-bottom: 8px;
                    justify-content: flex-start;
                    -webkit-overflow-scrolling: touch;
                }

                    .tab-row::-webkit-scrollbar {
                        height: 4px;
                    }

                    .tab-row::-webkit-scrollbar-thumb {
                        background: rgba(255,255,255,0.15);
                        border-radius: 4px;
                    }

                .tab {
                    white-space: nowrap;
                    padding: 8px 16px;
                    font-size: 0.85rem;
                }

                .main-content {
                    padding: 30px 20px;
                }

                .hero-title {
                    font-size: 2.2rem;
                }

                .hero-subtitle {
                    font-size: 1rem;
                }
 
                .help-grid {
                    grid-template-columns: 1fr;
                    gap: 15px;
                }

                .help-card {
                    padding: 25px 20px;
                }
            }
    </style>
</head>
<body>

    <nav class="navbar">
        <a asp-controller="Contactos" asp-action="Index" class="nav-brand">
            <div class="brand-icon">📒</div>
            <span class="brand-name">Agenda Web</span>
        </a>
        <div class="tab-row">
            <a asp-controller="Contactos" asp-action="Index" class="tab"><span>👥</span> Contactos</a>
            <a asp-controller="Categorias" asp-action="Index" class="tab"><span>📁</span> Categorías</a>
            <a asp-controller="Contactos" asp-action="Recientes" class="tab"><span>🕒</span> Recientes</a>
            <a asp-controller="Contactos" asp-action="Ayuda" class="tab active"><span>❓</span> Ayuda</a>
        </div>
    </nav>

    <main class="main-content">
        <div class="ambient-glow"></div>
        <div class="hero-section">
            <h1 class="hero-title">Centro de Ayuda</h1>
            <p class="hero-subtitle">Bienvenido al soporte de tu agenda. Encuentra respuestas rápidas y descubre cómo gestionar tus contactos de manera eficiente.</p>
        </div>
        <div class="help-grid">
            <div class="help-card">
                <div class="icon-box">🔍</div>
                <h3>Búsqueda</h3>
                <p>Encuentra personas al instante. Escribe un nombre en la barra de búsqueda para filtrar tu agenda en tiempo real.</p>
            </div>
            <div class="help-card">
                <div class="icon-box">⭐</div>
                <h3>Favoritos</h3>
                <p>Marca la estrella (★) en un contacto para anclarlo. Tus favoritos siempre aparecerán destacados.</p>
            </div>
            <div class="help-card">
                <div class="icon-box">📁</div>
                <h3>Categorías</h3>
                <p>Filtra tu agenda por grupos. Mantén tu red organizada y visualiza solo lo que necesitas en cada momento.</p>
            </div>
            <div class="help-card">
                <div class="icon-box">⚙️</div>
                <h3>Gestión</h3>
                <p>Usa el menú (⋮) para actualizar números telefónicos o eliminar contactos de tu red de forma rápida.</p>
            </div>
        </div>
    </main>

</body>
</html>