@model IEnumerable<ContactManagerWeb.Models.Contacto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    var nuevosIds = ViewBag.NuevosIds as List<int> ?? new List<int>();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agenda — Contact Manager Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            :root {
                --bg-sidebar: rgba(15, 15, 20, 0.85); /* Un poco más transparente */
                --bg-main: #07040D; 
                --bg-card: rgba(28, 28, 38, 0.6);
                --text-white: #FFFFFF;
                --text-muted: #8A8A9E;
                --border-color: rgba(255, 255, 255, 0.08);
                --accent: #6B5BFF;
                --accent-glow: rgba(107, 91, 255, 0.35);
                --danger: #FF5C5C;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
                font-family: 'DM Sans', sans-serif;
            }

            body {
                background-color: var(--bg-main);
                color: var(--text-white);
                min-height: 100vh;
                overflow-x: hidden;
                position: relative;
            }

            /* --- CUADRÍCULA Y LUCES DEL HOME AÑADIDAS AQUÍ --- */
            body::before {
                content: ''; position: absolute; inset: 0;
                background-image: 
                    linear-gradient(rgba(139, 92, 246, 0.03) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(139, 92, 246, 0.03) 1px, transparent 1px);
                background-size: 40px 40px; z-index: -2; pointer-events: none;
            }

            .ambient-light {
                position: fixed; border-radius: 50%; filter: blur(140px);
                z-index: -1; pointer-events: none; opacity: 0.3;
            }
            .light-1 { top: -10%; left: -10%; width: 500px; height: 500px; background: #5B21B6; }
            .light-2 { bottom: -20%; right: 10%; width: 600px; height: 600px; background: #4C1D95; }

            /* --- OVERLAY DE TRANSICIÓN OSCURO Y SUTIL (RÁPIDO) --- */
            .page-transition-overlay {
                position: fixed; inset: 0;
                background: rgba(7, 4, 13, 0.98); 
                backdrop-filter: blur(10px); 
                z-index: 99999;
                opacity: 1;
                pointer-events: none;
                transition: opacity 0.4s ease-out; 
            }
            body.loaded .page-transition-overlay { opacity: 0; }

            ::-webkit-scrollbar {
                width: 8px;
                height: 8px;
            }

            ::-webkit-scrollbar-track {
                background: transparent;
            }

            ::-webkit-scrollbar-thumb {
                background: #3E3E54;
                border-radius: 10px;
            }

                ::-webkit-scrollbar-thumb:hover {
                    background: var(--accent);
                }

            button, input {
                outline: none;
            }

            /* --- ANIMACIÓN DE ENFOQUE "COOL" (ÁGIL) --- */
            .app-container {
                display: flex;
                min-height: 100vh;
                position: relative;
                transform: scale(1.02); 
                filter: blur(4px); 
                transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease-out; 
            }
            
            /* Estado final al cargar */
            body.loaded .app-container {
                transform: scale(1);
                filter: blur(0px);
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes floatIcon {
                0% {
                    transform: translateY(0px);
                    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.4));
                }

                50% {
                    transform: translateY(-15px) rotate(5deg);
                    filter: drop-shadow(0 25px 20px rgba(0,0,0,0.2));
                }

                100% {
                    transform: translateY(0px);
                    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.4));
                }
            }

            .floating-icon {
                display: inline-block;
                animation: floatIcon 3.5s ease-in-out infinite;
            }

            /* --- SIDEBAR ILUMINADA --- */
            .sidebar {
                width: 280px;
                min-width: 280px;
                background-color: var(--bg-sidebar);
                background-image: 
                    linear-gradient(180deg, rgba(139, 92, 246, 0.15) 0%, transparent 40%), 
                    radial-gradient(circle at bottom right, rgba(91, 33, 182, 0.1) 0%, transparent 50%);
                backdrop-filter: blur(20px);
                border-right: 1px solid rgba(139, 92, 246, 0.15); /* Borde sutil morado */
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                z-index: 1000;
                transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                box-shadow: 5px 0 30px rgba(0,0,0,0.5), inset -2px 0 20px rgba(139, 92, 246, 0.05); /* Sombra interna */
            }

                .sidebar.collapsed {
                    transform: translateX(-280px);
                }

            .sidebar-inner {
                width: 100%;
                height: 100%;
                padding: 25px 20px;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

            .toggle-btn {
                position: absolute;
                top: 25px;
                right: 20px;
                width: 38px;
                height: 38px;
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid var(--border-color);
                color: var(--text-muted);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.95rem;
                cursor: pointer;
                z-index: 1001;
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

                .toggle-btn:hover {
                    background: var(--accent);
                    color: white;
                    border-color: var(--accent);
                    transform: scale(1.1);
                    box-shadow: 0 0 15px var(--accent-glow);
                }

            .sidebar.collapsed .toggle-btn {
                right: -55px;
                background: rgba(28, 28, 38, 0.8);
                backdrop-filter: blur(10px);
                border: 1px solid var(--border-color);
                color: white;
                box-shadow: 5px 0 20px rgba(0,0,0,0.5);
            }

            .mobile-overlay {
                display: none;
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(0,0,0,0.7);
                z-index: 999;
                backdrop-filter: blur(5px);
                opacity: 0;
                transition: opacity 0.3s ease;
            }

                .mobile-overlay.show {
                    display: block;
                    opacity: 1;
                }

            .logo-row {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 25px;
                flex-shrink: 0;
            }

            .logo-dot {
                background: linear-gradient(135deg, #9D88FF, #6B5BFF);
                width: 32px;
                height: 32px;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                box-shadow: 0 4px 15px var(--accent-glow);
            }

            .logo-name {
                font-weight: 800;
                font-size: 1.25rem;
                letter-spacing: 0.5px;
                background: linear-gradient(135deg, #FFFFFF, #A396FF);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .search-side {
                background: rgba(255, 255, 255, 0.02);
                border: 1px solid var(--border-color);
                border-radius: 12px;
                padding: 10px 15px;
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 25px;
                transition: all 0.3s ease;
                flex-shrink: 0;
            }

                .search-side:focus-within {
                    background: rgba(107, 91, 255, 0.05);
                    border-color: var(--accent);
                    box-shadow: 0 0 0 4px rgba(107, 91, 255, 0.1);
                }

                .search-side input {
                    background: transparent;
                    border: none;
                    color: white;
                    width: 100%;
                    font-size: 0.9rem;
                }

                .search-side button {
                    background: transparent;
                    border: none;
                    color: var(--text-muted);
                    cursor: pointer;
                    transition: 0.3s;
                }

            .sec-label {
                font-size: 0.7rem;
                font-weight: 800;
                color: #5C5C77;
                text-transform: uppercase;
                letter-spacing: 2px;
                margin: 15px 0 10px 5px;
                flex-shrink: 0;
            }

            .nav-item {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 10px 14px;
                border-radius: 12px;
                color: var(--text-muted);
                text-decoration: none;
                transition: all 0.3s ease;
                margin-bottom: 4px;
                flex-shrink: 0;
                border: 1px solid transparent;
            }

                .nav-item:hover {
                    background: rgba(255,255,255,0.03);
                    color: white;
                    transform: translateX(4px);
                }

                .nav-item.active {
                    background: linear-gradient(90deg, rgba(107, 91, 255, 0.15) 0%, transparent 100%);
                    color: white;
                    border-left: 3px solid var(--accent);
                    border-radius: 4px 12px 12px 4px;
                }

            .nav-left {
                display: flex;
                align-items: center;
                gap: 12px;
                font-weight: 500;
                font-size: 0.95rem;
            }

            .nav-count {
                background-color: rgba(255,255,255,0.05);
                font-size: 0.7rem;
                padding: 3px 8px;
                border-radius: 8px;
                font-weight: 700;
                color: #A396FF;
            }

            .nav-item.active .nav-count {
                background-color: var(--accent);
                color: white;
                box-shadow: 0 2px 8px var(--accent-glow);
            }

            .add-cat-btn {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                padding: 12px;
                border: 1px dashed rgba(107, 91, 255, 0.4);
                border-radius: 12px;
                color: #A396FF;
                text-decoration: none;
                font-size: 0.8rem;
                font-weight: 700;
                transition: all 0.3s ease;
                background: rgba(107, 91, 255, 0.02);
                flex-shrink: 0;
                margin-bottom: 15px;
            }

                .add-cat-btn:hover {
                    border-style: solid;
                    border-color: var(--accent);
                    color: white;
                    background: rgba(107, 91, 255, 0.1);
                    transform: translateY(-2px);
                    box-shadow: 0 4px 15px rgba(107, 91, 255, 0.15);
                }

            .categories-container {
                flex: 1;
                min-height: 0;
                overflow-y: auto;
                overflow-x: hidden;
                margin-bottom: 10px;
                padding-right: 5px;
            }

                .categories-container::-webkit-scrollbar {
                    width: 4px;
                }

                .categories-container::-webkit-scrollbar-thumb {
                    background: transparent;
                    border-radius: 4px;
                }

                .categories-container:hover::-webkit-scrollbar-thumb {
                    background: #3E3E54;
                }

            .cat-item-wrapper {
                display: flex;
                align-items: center;
                margin-bottom: 2px;
            }

                .cat-item-wrapper .nav-item {
                    flex: 1;
                    margin-bottom: 0;
                    padding: 8px 12px;
                }

            .sidebar-footer {
                margin-top: auto;
                padding-top: 15px;
                flex-shrink: 0;
            }

            .add-btn {
                display: block;
                text-align: center;
                background: linear-gradient(135deg, var(--accent), #8375FF);
                color: white;
                text-decoration: none;
                padding: 12px;
                border-radius: 12px;
                font-weight: 700;
                font-size: 0.9rem;
                transition: all 0.3s ease;
                box-shadow: 0 6px 15px var(--accent-glow);
            }

                .add-btn:hover {
                    transform: translateY(-3px);
                    filter: brightness(1.1);
                    box-shadow: 0 10px 20px var(--accent-glow);
                    color: white;
                }

            /* --- BOTÓN SALIR PRO --- */
            .exit-link {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                margin-top: 15px;
                padding: 10px;
                border-radius: 12px;
                color: var(--text-muted);
                text-decoration: none;
                font-size: 0.85rem;
                font-weight: 700;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                border: 1px solid transparent;
            }

                .exit-link i {
                    font-size: 1.1rem;
                    transition: transform 0.3s ease;
                }

                .exit-link:hover {
                    background: rgba(255, 92, 92, 0.08);
                    color: #FF7070;
                    border-color: rgba(255, 92, 92, 0.2);
                    transform: translateY(-2px);
                }

                    .exit-link:hover i {
                        transform: translateX(-3px);
                    }

            /* --- MAIN --- */
            .main {
                flex: 1;
                margin-left: 280px;
                padding: 30px 50px 60px 50px;
                transition: margin-left 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                min-width: 0;
            }

                .main.expanded {
                    margin-left: 0;
                }

                    .main.expanded .topbar {
                        padding-left: 55px;
                        transition: padding-left 0.5s ease;
                    }

            .topbar {
                display: flex;
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 40px;
                gap: 20px;
                animation: fadeUp 0.6s ease-out forwards;
                transition: padding-left 0.5s ease;
                border-bottom: 1px solid rgba(255,255,255,0.03);
                padding-bottom: 20px;
            }

            .page-title {
                font-size: 2.2rem;
                font-weight: 800;
                letter-spacing: -1px;
                margin: 0;
                background: linear-gradient(135deg, #FFFFFF, #BDB2FF);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                text-shadow: 0 10px 30px rgba(107, 91, 255, 0.2);
            }

            .tab-row {
                display: flex;
                gap: 6px;
                background: rgba(0, 0, 0, 0.4);
                padding: 6px;
                border-radius: 16px;
                border: 1px solid rgba(255, 255, 255, 0.05);
                box-shadow: inset 0 4px 10px rgba(0,0,0,0.5);
                flex-wrap: wrap;
                align-items: center;
            }

            .tab {
                color: #8A8A9E;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.9rem;
                padding: 10px 18px;
                border-radius: 12px;
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .tab:hover {
                    color: white;
                    background: rgba(255,255,255,0.03);
                    transform: translateY(-2px);
                }

                .tab.active {
                    background: linear-gradient(135deg, var(--accent), #8375FF);
                    color: white;
                    box-shadow: 0 6px 20px rgba(107, 91, 255, 0.4);
                    transform: translateY(-2px);
                }

            .grid-label {
                font-size: 0.8rem;
                font-weight: 800;
                color: #5C5C77;
                text-transform: uppercase;
                letter-spacing: 2px;
                margin-bottom: 15px;
                animation: fadeUp 0.5s ease-out forwards;
            }

            /* --- CARDS --- */
            .contact-item-wrapper {
                position: relative;
                z-index: 1;
            }

            .fav-card, .c-card {
                position: relative;
                border-radius: 16px;
                padding: 14px 18px;
                display: flex;
                align-items: center;
                gap: 12px;
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                animation: fadeUp 0.6s ease-out forwards;
                height: 100%;
                backdrop-filter: blur(12px);
                z-index: 1;
            }

            .fav-card {
                background: linear-gradient(145deg, rgba(42, 35, 82, 0.7), rgba(28, 28, 38, 0.9));
                border: 1px solid rgba(123, 107, 255, 0.2);
            }

            .c-card {
                background: rgba(28, 28, 38, 0.5);
                border: 1px solid rgba(255, 255, 255, 0.05);
            }

            .contact-item-wrapper:hover {
                z-index: 50;
            }

                .contact-item-wrapper:hover .fav-card, .contact-item-wrapper:hover .c-card {
                    transform: translateY(-4px);
                }

                .contact-item-wrapper:hover .fav-card {
                    border-color: rgba(123, 107, 255, 0.8);
                    box-shadow: 0 12px 25px rgba(107, 91, 255, 0.2), inset 0 0 15px rgba(107, 91, 255, 0.05);
                }

                .contact-item-wrapper:hover .c-card {
                    border-color: rgba(255, 255, 255, 0.15);
                    background: rgba(28, 28, 38, 0.8);
                    box-shadow: 0 12px 25px rgba(0,0,0,0.4);
                }

            .avatar-box {
                width: 44px;
                height: 44px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.2rem;
                font-weight: 800;
                flex-shrink: 0;
                transition: transform 0.4s ease;
            }

            .fav-card:hover .avatar-box, .c-card:hover .avatar-box {
                transform: scale(1.1) rotate(5deg);
            }

            .card-info-flex {
                flex: 1;
                min-width: 0;
            }

            .contact-name {
                font-size: 1rem;
                font-weight: 700;
                margin-bottom: 2px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                color: #FFFFFF;
                letter-spacing: -0.3px;
            }

            .contact-phone {
                color: #8A8A9E;
                font-size: 0.8rem;
                font-weight: 500;
            }

            .badge-nuevo {
                background: rgba(107, 91, 255, 0.15);
                border: 1px solid rgba(107, 91, 255, 0.3);
                color: #BDB2FF;
                font-size: 0.6rem;
                padding: 3px 6px;
                border-radius: 5px;
                font-weight: 800;
                text-transform: uppercase;
                margin-right: 10px;
                letter-spacing: 1px;
            }

            .star-toggle-btn {
                background: none;
                border: none;
                padding: 0;
                cursor: pointer;
                transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

                .star-toggle-btn:hover {
                    transform: scale(1.3) rotate(20deg);
                    filter: drop-shadow(0 0 8px rgba(251, 191, 36, 0.6));
                }

            /* --- DROPDOWNS --- */
            .dropdown {
                position: relative;
                display: inline-flex;
                align-items: center;
                margin-left: 2px;
            }

            .dropdown-btn {
                background: transparent;
                border: none;
                color: var(--text-muted);
                font-size: 1.4rem;
                cursor: pointer;
                font-weight: bold;
                padding: 0 5px;
                transition: color 0.3s;
            }

            .dropdown:hover .dropdown-btn {
                color: white;
            }

            .dropdown-content {
                visibility: hidden;
                opacity: 0;
                position: absolute;
                bottom: 100%;
                top: auto;
                right: 0; 
                left: auto; 
                margin-bottom: 8px;
                background: rgba(20, 20, 28, 0.98);
                backdrop-filter: blur(15px);
                width: max-content;
                min-width: 180px;
                max-width: 260px;
                box-shadow: -5px -10px 30px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.05);
                border-radius: 12px;
                padding: 6px;
                transition: all 0.2s ease-out;
                transform: translateY(10px);
                z-index: 99999;
            }

            .dropdown:hover .dropdown-content {
                visibility: visible;
                opacity: 1;
                transform: translateY(0);
            }

            .dropdown.drop-down-force .dropdown-content {
                bottom: auto;
                top: 100%;
                margin-bottom: 0;
                margin-top: 8px;
                transform: translateY(-10px);
                box-shadow: -5px 10px 30px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.05);
            }

            .dropdown.drop-down-force:hover .dropdown-content {
                transform: translateY(0);
            }

            .cat-dropdown-portal {
                display: none;
                position: fixed;
                visibility: visible;
                opacity: 1;
                z-index: 999999;
                background: rgba(20, 20, 28, 0.98);
                backdrop-filter: blur(15px);
                width: max-content;
                min-width: 150px;
                box-shadow: 5px 10px 30px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.05);
                border-radius: 12px;
                padding: 6px;
            }

                .cat-dropdown-portal.show {
                    display: block;
                    animation: fadeUp 0.2s ease forwards;
                }

                .dropdown-content a, .dropdown-content .btn-delete, .cat-dropdown-portal a, .cat-dropdown-portal .btn-delete {
                    color: #E2E2E9;
                    padding: 10px 14px;
                    text-decoration: none;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    width: 100%;
                    text-align: left;
                    font-size: 0.85rem;
                    font-weight: 500;
                    border-radius: 8px;
                    background: transparent;
                    border: none;
                    cursor: pointer;
                    transition: all 0.2s;
                }

                    .dropdown-content a:hover, .cat-dropdown-portal a:hover {
                        background: rgba(107, 91, 255, 0.15);
                        color: white;
                        padding-left: 16px;
                    }

                .dropdown-content .btn-delete, .cat-dropdown-portal .btn-delete {
                    color: #FF5C5C;
                }

                    .dropdown-content .btn-delete:hover, .cat-dropdown-portal .btn-delete:hover {
                        background: rgba(255, 92, 92, 0.1);
                        color: #FF7070;
                        padding-left: 16px;
                    }

            .empty-state-glow {
                position: absolute;
                width: 300px;
                height: 300px;
                background: var(--accent);
                filter: blur(120px);
                opacity: 0.15;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                pointer-events: none;
                z-index: 0;
            }

            @@media (max-width: 991.98px) {
                .sidebar {
                    transform: translateX(-280px);
                }

                    .sidebar .toggle-btn {
                        right: -50px;
                        background: rgba(28, 28, 38, 0.9);
                        backdrop-filter: blur(10px);
                    }

                    .sidebar.mobile-open {
                        transform: translateX(0);
                    }

                .main {
                    margin-left: 0 !important;
                    padding: 20px 15px 40px 15px;
                }

                .topbar {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 15px;
                    padding-left: 45px;
                }

                .dropdown-content {
                    right: 0;
                    left: auto;
                }
            }
    </style>
</head>
<body>

    <div class="page-transition-overlay" id="transitionOverlay"></div>

    <script>
        // SCRIPT DE DETECCIÓN INTELIGENTE
        // Solo hacer la transición suave si NO venimos navegando dentro de la misma aplicación
        const ref = document.referrer.toLowerCase();
        if (ref.includes('/contactos') || ref.includes('/categorias')) {
            document.getElementById('transitionOverlay').style.display = 'none';
            document.body.classList.add('loaded'); // Entra inmediato
        } else {
            // Si venimos del Home o de afuera, ejecuta la animación de entrada
            setTimeout(() => {
                document.body.classList.add('loaded');
            }, 50);
        }
    </script>

    <div class="ambient-light light-1"></div>
    <div class="ambient-light light-2"></div>

    <div class="app-container">
        <div id="mobileOverlay" class="mobile-overlay"></div>

        <aside class="sidebar" id="mainSidebar">
            <button id="toggleBtn" class="toggle-btn" title="Menú">
                <span id="toggleIcon" style="line-height: 1; margin-bottom: 2px;">◀</span>
            </button>

            <div class="sidebar-inner">
                <div class="logo-row">
                    <div class="logo-dot">📒</div>
                    <span class="logo-name">Agenda Web</span>
                </div>

                <form class="search-side" asp-action="Index" method="get">
                    <button type="submit" style="font-size:16px">⌕</button>
                    <input type="text" id="liveSearchInput" name="searchString" placeholder="Buscar contacto..." value="@Context.Request.Query["searchString"]" autocomplete="off" />
                </form>

                <div class="sec-label">Vistas</div>
                <a asp-action="Index" class="nav-item @(string.IsNullOrEmpty(Context.Request.Query["soloFavoritos"]) && string.IsNullOrEmpty(Context.Request.Query["categoria"]) ? "active" : "")">
                    <div class="nav-left"><span>👥</span><span class="nav-text">Todos</span></div>
                    <span class="nav-count">@(ViewBag.TotalTodos ?? 0)</span>
                </a>
                <a asp-action="Index" asp-route-soloFavoritos="true" class="nav-item @(Context.Request.Query["soloFavoritos"] == "true" ? "active" : "")">
                    <div class="nav-left"><span>⭐</span><span class="nav-text">Favoritos</span></div>
                    <span class="nav-count">@(ViewBag.TotalFavoritos ?? 0)</span>
                </a>

                <div class="sec-label">Categorías</div>
                <a asp-controller="Categorias" asp-action="Crear" class="add-cat-btn">
                    <span style="font-size: 1.2rem; line-height: 1; font-weight: 400;">+</span>
                    <span>Añadir Categoría</span>
                </a>

                <div class="categories-container" id="catContainer">
                    @if (ViewBag.CategoriasDinamicas != null)
                    {
                        foreach (var cat in ViewBag.CategoriasDinamicas)
                        {
                            if (cat.NombreCategoria == "General") continue;

                            <div class="cat-item-wrapper">
                                <a asp-action="Index" asp-route-categoria="@cat.NombreCategoria" class="nav-item @(Context.Request.Query["categoria"] == cat.NombreCategoria ? "active" : "")">
                                    <div class="nav-left">
                                        <span style="font-size: 1.05rem;">@(string.IsNullOrEmpty(cat.Emoji) ? "📁" : cat.Emoji)</span>
                                        <span class="nav-text">@cat.NombreCategoria</span>
                                    </div>
                                    <span class="nav-count">@cat.Count</span>
                                </a>
                                <div class="cat-trigger-wrap" style="padding-right: 5px; position: relative;">
                                    <button class="dropdown-btn trigger-cat-menu">⋮</button>
                                    <div class="cat-dropdown-portal">
                                        <a asp-controller="Categorias" asp-action="Detalles" asp-route-id="@cat.Id">👀 Detalles</a>
                                        <a asp-controller="Categorias" asp-action="Editar" asp-route-id="@cat.Id" asp-route-volverA="Contactos">✏️ Editar</a>
                                        <a asp-controller="Categorias" asp-action="Eliminar" asp-route-id="@cat.Id" asp-route-volverA="Contactos" class="btn-delete">🗑️ Eliminar</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="sidebar-footer">
                    <a class="add-btn" asp-action="Crear">+ Nuevo contacto</a>

                    <a asp-controller="Home" asp-action="Index" class="exit-link">
                        <i class="bi bi-door-open"></i>
                        <span>Salir al Inicio</span>
                    </a>
                </div>
            </div>
        </aside>

        <main class="main" id="mainContent">
            <div class="topbar">
                <h1 class="page-title">
                    @(ViewData["FiltroActual"] != null ? ViewData["FiltroActual"] : "Agenda de Contactos")
                </h1>
                <div class="tab-row">
                    <a asp-controller="Contactos" asp-action="Index" class="tab active"><span>👥</span> Contactos</a>
                    <a asp-controller="Categorias" asp-action="Index" class="tab"><span>📁</span> Categorías</a>
                    <a asp-controller="Contactos" asp-action="Recientes" class="tab"><span>🕒</span> Recientes</a>
                    <a asp-controller="Contactos" asp-action="Ayuda" class="tab"><span>❓</span> Ayuda</a>
                </div>
            </div>

            <div class="content">
                <div id="dynamicEmptyState" style="display: none; text-align: center; padding: 60px 20px; background: rgba(28, 28, 38, 0.3); border-radius: 20px; border: 1px dashed rgba(107, 91, 255, 0.2); backdrop-filter: blur(10px); position: relative; overflow: hidden;">
                    <div class="empty-state-glow"></div>
                    <div class="floating-icon" style="font-size: 4.5rem; margin-bottom: 20px;">🔍</div>
                    <h3 style="color: var(--text-white); font-size: 1.8rem; font-weight: 800;">No hay resultados</h3>
                    <p style="color: #D1D1E0;">No coincide ningún contacto con tu búsqueda.</p>
                </div>

                @if (!Model.Any())
                {
                    <div class="empty-state text-center p-5 mt-3" style="background: rgba(28, 28, 38, 0.3); border-radius: 20px; border: 1px dashed rgba(107, 91, 255, 0.2);">
                        <div class="empty-state-glow"></div>
                        <div class="floating-icon" style="font-size: 5rem; margin-bottom: 15px;">📭</div>
                        <h3 class="fw-bold mb-3">No hay contactos aquí</h3>
                        <p class="mb-4" style="color: #D1D1E0; max-width: 420px; margin: 0 auto 25px auto;">No encontramos ningún contacto en esta categoría o búsqueda. ¿Creamos uno nuevo?</p>
                        <div class="d-flex gap-3 justify-content-center flex-wrap">
                            <a asp-action="Crear" class="btn" style="background: linear-gradient(135deg, var(--accent), #8375FF); color: white; border-radius: 12px; padding: 12px 28px; font-weight: 700; box-shadow: 0 8px 20px var(--accent-glow);">+ Nuevo Contacto</a>
                            <a asp-action="Index" class="btn" style="background: rgba(255, 255, 255, 0.05); color: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 12px 28px;">Mostrar Todos</a>
                        </div>
                    </div>
                }
                else
                {
                    var favoritos = Model.Where(c => c.EsFavorito).ToList();
                    var otros = Model.Where(c => !c.EsFavorito).ToList();

                    if (favoritos.Any())
                    {
                        var favGradients = new[] { "linear-gradient(135deg, #6366f1, #a855f7)", "linear-gradient(135deg, #3b82f6, #2dd4bf)", "linear-gradient(135deg, #f43f5e, #fb923c)", "linear-gradient(135deg, #22c55e, #84cc16)", "linear-gradient(135deg, #8b5cf6, #d946ef)", "linear-gradient(135deg, #f59e0b, #eab308)" };
                        int countFav = 0;

                        <div class="grid-label section-label-fav">⭐ Contactos Favoritos</div>
                        <div class="row g-3 mb-5 section-grid-fav">
                            @foreach (var item in favoritos)
                            {
                                var grad = favGradients[countFav % 6]; countFav++;
                                <div class="col-12 col-md-6 col-xl-4 contact-item-wrapper fav-wrapper">
                                    <div class="fav-card h-100">
                                        <div class="avatar-box" style="background: @grad; color: white;">@(string.IsNullOrEmpty(item.Nombre) ? "?" : item.Nombre.Substring(0, 1).ToUpper())</div>
                                        <div class="card-info-flex">
                                            <div class="contact-name searchable-name" title="@item.Nombre @item.Apellido">@item.Nombre @item.Apellido</div>
                                            <div class="contact-phone searchable-phone">@(item.Telefonos?.FirstOrDefault()?.Numero ?? "Sin teléfono")</div>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            @if (nuevosIds.Contains(item.Id))
                                            {
                                                <span class="badge-nuevo">Nuevo</span>
                                            }
                                            <form asp-action="ToggleFavorito" asp-route-id="@item.Id" method="post" class="me-1">
                                                <button type="submit" class="star-toggle-btn"><span style="color: #FBBF24; font-size: 1.3rem;">★</span></button>
                                            </form>
                                            <div class="dropdown">
                                                <button class="dropdown-btn">⋮</button>
                                                <div class="dropdown-content">
                                                    <a asp-action="Detalles" asp-route-id="@item.Id">👀 Detalles</a>
                                                    
                                                    <a asp-action="Editar" asp-route-id="@item.Id">
                                                        📁 @(item.Categoria == null || item.Categoria.NombreCategoria == "General" ? "Asignar Categoría" : "Cambiar Categoría")
                                                    </a>
                                                    
                                                    <a asp-action="Editar" asp-route-id="@item.Id">✏️ Editar</a>
                                                    <a asp-action="Eliminar" asp-route-id="@item.Id" class="btn-delete">🗑️ Eliminar</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    if (otros.Any())
                    {
                        var neonPalette = new (string Bg, string Text)[] { ("rgba(99, 102, 241, 0.1)", "#818cf8"), ("rgba(16, 185, 129, 0.1)", "#34d399"), ("rgba(244, 63, 94, 0.1)", "#fb7185"), ("rgba(234, 179, 8, 0.1)", "#facc15"), ("rgba(168, 85, 247, 0.1)", "#c084fc"), ("rgba(6, 182, 212, 0.1)", "#22d3ee") };
                        int countOtros = 0;

                        <div class="grid-label section-label-others">👥 Otros Contactos</div>
                        <div class="row g-3 section-grid-others mb-4">
                            @foreach (var contact in otros)
                            {
                                var style = neonPalette[countOtros % 6]; countOtros++;
                                <div class="col-12 col-md-6 col-xl-4 contact-item-wrapper others-wrapper">
                                    <div class="c-card h-100">
                                        <div class="avatar-box" style="background-color: @style.Bg; border: 1.5px solid @style.Text; color: @style.Text;">@(string.IsNullOrEmpty(contact.Nombre) ? "?" : contact.Nombre.Substring(0, 1).ToUpper())</div>
                                        <div class="card-info-flex">
                                            <div class="contact-name searchable-name" title="@contact.Nombre @contact.Apellido">@contact.Nombre @contact.Apellido</div>
                                            <div class="contact-phone searchable-phone">@(contact.Telefonos?.FirstOrDefault()?.Numero ?? "Sin teléfono")</div>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            @if (nuevosIds.Contains(contact.Id))
                                            {
                                                <span class="badge-nuevo">Nuevo</span>
                                            }
                                            <form asp-action="ToggleFavorito" asp-route-id="@contact.Id" method="post" class="me-1">
                                                <button type="submit" class="star-toggle-btn"><span style="color: #4A4A63; font-size: 1.3rem;">★</span></button>
                                            </form>
                                            <div class="dropdown">
                                                <button class="dropdown-btn">⋮</button>
                                                <div class="dropdown-content">
                                                    <a asp-action="Detalles" asp-route-id="@contact.Id">👀 Detalles</a>
                                                    
                                                    <a asp-action="Editar" asp-route-id="@contact.Id">
                                                        📁 @(contact.Categoria == null || contact.Categoria.NombreCategoria == "General" ? "Asignar Categoría" : "Cambiar Categoría")
                                                    </a>
                                                    
                                                    <a asp-action="Editar" asp-route-id="@contact.Id">✏️ Editar</a>
                                                    <a asp-controller="Categorias" asp-action="Eliminar" asp-route-id="@contact.Id" asp-route-volverA="Contactos" class="btn-delete">🗑️ Eliminar</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('mainSidebar');
            const mainContent = document.getElementById('mainContent');
            const toggleBtn = document.getElementById('toggleBtn');
            const toggleIcon = document.getElementById('toggleIcon');
            const mobileOverlay = document.getElementById('mobileOverlay');

            if (window.innerWidth < 992) {
                sidebar.classList.add('collapsed');
                toggleIcon.textContent = '☰';
            }

            function toggleSidebar() {
                if (window.innerWidth < 992) {
                    sidebar.classList.toggle('mobile-open');
                    mobileOverlay.classList.toggle('show');
                    toggleIcon.textContent = sidebar.classList.contains('mobile-open') ? '◀' : '☰';
                } else {
                    sidebar.classList.toggle('collapsed');
                    mainContent.classList.toggle('expanded');
                    toggleIcon.textContent = sidebar.classList.contains('collapsed') ? '☰' : '◀';
                }
            }

            toggleBtn.addEventListener('click', toggleSidebar);
            mobileOverlay.addEventListener('click', toggleSidebar);

            const catMenus = document.querySelectorAll('.cat-dropdown-portal');
            catMenus.forEach(menu => document.body.appendChild(menu));

            const triggerWraps = document.querySelectorAll('.cat-trigger-wrap');
            let hideTimeout;

            const hideAllCatMenus = () => {
                document.querySelectorAll('.cat-dropdown-portal.show').forEach(m => m.classList.remove('show'));
            };

            triggerWraps.forEach((wrap, index) => {
                const btn = wrap.querySelector('.trigger-cat-menu');
                const menu = catMenus[index];

                wrap.addEventListener('mouseenter', () => {
                    clearTimeout(hideTimeout);
                    hideAllCatMenus();
                    const rect = btn.getBoundingClientRect();
                    menu.style.top = `${rect.top - 5}px`;
                    menu.style.left = `${rect.right + 15}px`;
                    menu.classList.add('show');
                });

                wrap.addEventListener('mouseleave', () => {
                    hideTimeout = setTimeout(() => { menu.classList.remove('show'); }, 200);
                });

                menu.addEventListener('mouseenter', () => clearTimeout(hideTimeout));
                menu.addEventListener('mouseleave', () => {
                    hideTimeout = setTimeout(() => menu.classList.remove('show'), 200);
                });
            });

            const dropdowns = document.querySelectorAll('.dropdown');
            dropdowns.forEach(dropdown => {
                dropdown.addEventListener('mouseenter', function() {
                    const rect = this.getBoundingClientRect();
                    if (rect.top < 180) this.classList.add('drop-down-force');
                    else this.classList.remove('drop-down-force');
                });
            });

            const searchInput = document.getElementById('liveSearchInput');
            const wrappers = document.querySelectorAll('.contact-item-wrapper');
            const emptyState = document.getElementById('dynamicEmptyState');

            const labelFav = document.querySelector('.section-label-fav');
            const gridFav = document.querySelector('.section-grid-fav');
            const labelOthers = document.querySelector('.section-label-others');
            const gridOthers = document.querySelector('.section-grid-others');

            if(searchInput) {
                searchInput.addEventListener('input', function() {
                    const query = this.value.toLowerCase().trim();
                    let visibleCount = 0;
                    let visibleFav = 0;
                    let visibleOthers = 0;

                    wrappers.forEach(wrap => {
                        const nameEl = wrap.querySelector('.searchable-name');
                        const phoneEl = wrap.querySelector('.searchable-phone');
                        if(!nameEl || !phoneEl) return;

                        const name = nameEl.textContent.toLowerCase();
                        const phone = phoneEl.textContent.toLowerCase();

                        if (name.includes(query) || phone.includes(query)) {
                            wrap.style.display = "";
                            visibleCount++;
                            if (wrap.classList.contains('fav-wrapper')) visibleFav++;
                            else visibleOthers++;
                        } else { wrap.style.display = "none"; }
                    });

                    if (labelFav) labelFav.style.display = (visibleFav > 0) ? "" : "none";
                    if (gridFav) gridFav.style.display = (visibleFav > 0) ? "" : "none";
                    if (labelOthers) labelOthers.style.display = (visibleOthers > 0) ? "" : "none";
                    if (gridOthers) gridOthers.style.display = (visibleOthers > 0) ? "" : "none";

                    if (emptyState) {
                        emptyState.style.display = (visibleCount === 0 && query !== "") ? "block" : "none";
                    }
                });
            }
        });
    </script>
</body>
</html>