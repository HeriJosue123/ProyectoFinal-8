@model IEnumerable<ContactManagerWeb.Models.Contacto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    var nuevosIds = ViewBag.NuevosIds as List<int> ?? new List<int>();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agenda — Contact Manager Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-sidebar: #0F0F14;
            --bg-main: #13131A; 
            --bg-card: #1C1C26;
            --text-white: #FFFFFF;
            --text-muted: #8A8A9E;
            --border-color: #2D2D3D;
            --accent: #6B5BFF; 
            --accent-glow: rgba(107, 91, 255, 0.25);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'DM Sans', sans-serif;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-white);
            min-height: 100vh;
            overflow-x: hidden;
        }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-main); }
        ::-webkit-scrollbar-thumb { background: #3E3E54; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        button, input { font-family: 'DM Sans', sans-serif; outline: none; }
        .app { display: flex; min-height: 100vh; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @@keyframes floatIcon {
            0% { transform: translateY(0px); filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3)); }
            50% { transform: translateY(-12px) rotate(5deg); filter: drop-shadow(0 20px 20px rgba(0,0,0,0.2)); }
            100% { transform: translateY(0px); filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3)); }
        }

        .sidebar {
            width: 280px; 
            min-width: 280px; 
            background-color: var(--bg-sidebar);
            border-right: 1px solid var(--border-color); 
            display: flex; 
            flex-direction: column;
            padding: 25px 20px; 
            animation: slideInLeft 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            z-index: 999; 
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            overflow-y: auto;
        }
        
        .sidebar::-webkit-scrollbar { width: 4px; }
        .sidebar::-webkit-scrollbar-thumb { background: transparent; }
        .sidebar:hover::-webkit-scrollbar-thumb { background: #3E3E54; }

        .sidebar.collapsed { transform: translateX(-280px); }

        .logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 25px; flex-shrink: 0; }
        .logo-dot {
            background: linear-gradient(135deg, #9D88FF, #6B5BFF); width: 34px; height: 34px;
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            font-size: 16px; box-shadow: 0 4px 15px var(--accent-glow);
        }
        .logo-name { font-weight: 700; font-size: 1.15rem; letter-spacing: 0.5px; }

        .search-side {
            background-color: #1C1C26; border: 1px solid var(--border-color); border-radius: 12px;
            padding: 12px 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 30px;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); flex-shrink: 0;
        }
        .search-side:focus-within { border-color: var(--accent); box-shadow: 0 0 0 4px rgba(107, 91, 255, 0.15); }
        .search-side input { background: transparent; border: none; color: white; width: 100%; font-size: 0.95rem; }
        .search-side button { background: transparent; border: none; color: var(--text-muted); cursor: pointer; }
        .search-side:focus-within button { color: var(--accent); }

        .sec-label { font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin: 20px 0 10px 5px; flex-shrink: 0; }

        .nav-item {
            display: flex; justify-content: space-between; align-items: center; padding: 12px 14px;
            border-radius: 10px; color: var(--text-muted); text-decoration: none;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); margin-bottom: 5px; flex-shrink: 0;
        }
        .nav-item:hover, .nav-item.active { background-color: #2A254D; color: white; transform: translateX(6px); }

        .nav-left { display: flex; align-items: center; gap: 12px; font-weight: 500; }
        .nav-count { background-color: rgba(255,255,255,0.05); font-size: 0.75rem; padding: 3px 8px; border-radius: 8px; font-weight: 600; }
        .nav-item.active .nav-count { background-color: var(--accent); color: white; }

        .categories-container {
            max-height: 220px; 
            overflow-y: auto; 
            overflow-x: hidden; 
            background: rgba(255, 255, 255, 0.02); 
            border: 1px solid rgba(255, 255, 255, 0.05); 
            border-radius: 14px; 
            padding: 8px; 
            margin-bottom: 10px; 
            flex-shrink: 0;
        }
        
        .categories-container::-webkit-scrollbar { width: 4px; }
        .categories-container::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }
        .categories-container::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        .cat-item-wrapper { display: flex; align-items: center; border-radius: 10px; margin-bottom: 4px; transition: background 0.3s ease; }
        .cat-item-wrapper:hover { background: rgba(107, 91, 255, 0.08); }
        .cat-item-wrapper .nav-item { margin-bottom: 0; flex: 1; background: transparent !important; transform: none !important; padding: 10px 12px; }

        .add-cat-btn {
            display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px;
            border: 1px dashed rgba(107, 91, 255, 0.3); border-radius: 12px; color: var(--text-muted); text-decoration: none;
            font-size: 0.85rem; font-weight: 600; transition: all 0.3s ease; background: rgba(255, 255, 255, 0.01); 
            flex-shrink: 0; margin-bottom: 20px; /* Separación extra */
        }
        .add-cat-btn:hover { border-style: solid; border-color: var(--accent); color: white; background: rgba(107, 91, 255, 0.1); transform: translateY(-2px); }

        .sidebar-footer { margin-top: auto; padding-top: 20px; flex-shrink: 0; }
        .add-btn {
            display: block; text-align: center; background-color: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color);
            color: white; text-decoration: none; padding: 14px; border-radius: 16px; font-weight: 600; transition: all 0.3s ease;
        }
        .add-btn:hover { background-color: var(--accent); border-color: var(--accent); transform: translateY(-3px); box-shadow: 0 8px 20px var(--accent-glow); }

        .main {
            flex: 1; display: flex; flex-direction: column; 
            margin-left: 280px; 
            padding: 40px 60px 80px 60px; 
            transition: margin-left 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            position: relative; z-index: 1;
        }
        .main.expanded { margin-left: 0; }

        .topbar {
            display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color);
            padding-bottom: 20px; margin-bottom: 30px; animation: fadeUp 0.5s ease-out forwards;
        }
        .title-wrapper { display: flex; align-items: center; gap: 15px; }
        .toggle-btn {
            background: var(--bg-card); border: 1px solid var(--border-color); color: var(--text-white); width: 44px; height: 44px;
            border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; transition: all 0.3s ease;
        }
        .toggle-btn:hover { background: var(--accent); border-color: var(--accent); transform: scale(1.08); box-shadow: 0 4px 15px var(--accent-glow); }
        .page-title { font-family: 'DM Sans', sans-serif; font-size: 2.2rem; font-weight: 700; letter-spacing: -0.5px; }

        .tab-row { display: flex; gap: 25px; }
        .tab { color: var(--text-muted); text-decoration: none; font-weight: 500; transition: color 0.3s ease; position: relative; padding-bottom: 8px; }
        .tab.active { color: white; }
        .tab.active::after {
            content: ''; position: absolute; bottom: -22px; left: 0; width: 100%; height: 3px;
            background-color: var(--accent); border-radius: 3px 3px 0 0; box-shadow: 0 -2px 10px var(--accent-glow);
        }
        .tab:hover { color: white; }

        .grid-label { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 18px; animation: fadeUp 0.5s ease-out forwards; }
        .contacts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; margin-bottom: 40px; }

        .fav-card, .c-card {
            position: relative; z-index: 1; border-radius: 18px; padding: 16px 20px; display: flex; align-items: center; gap: 15px;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); opacity: 0; animation: fadeUp 0.6s ease-out forwards;
        }
        .fav-card { background: linear-gradient(145deg, #2A2352 0%, var(--bg-card) 100%); border: 1px solid #4B3F85; }
        .c-card { background-color: var(--bg-card); border: 1px solid var(--border-color); }
        
        .fav-card:hover, .c-card:hover { z-index: 100; transform: translateY(-4px); }
        .fav-card:hover { border-color: #7B6BFF; box-shadow: 0 12px 30px rgba(90, 79, 207, 0.25); }
        .c-card:hover { border-color: #4A4A63; box-shadow: 0 12px 30px rgba(0,0,0,0.3); }

        .avatar-box { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 700; flex-shrink: 0; transition: transform 0.3s ease; }
        .fav-card:hover .avatar-box, .c-card:hover .avatar-box { transform: scale(1.05); }

        .fav-info, .c-info { flex: 1; min-width: 0; }
        .fav-name, .c-name { font-size: 1.05rem; font-weight: 600; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #F8F8F8; }
        .fav-detail, .c-phone { color: var(--text-muted); font-size: 0.85rem; }

        .badge-nuevo {
            background: rgba(107, 91, 255, 0.15); border: 1px solid rgba(107, 91, 255, 0.4); color: #A396FF;
            font-size: 0.65rem; padding: 4px 8px; border-radius: 6px; font-weight: 700; text-transform: uppercase; margin-right: 10px;
        }
        .star-toggle-btn { background: none; border: none; padding: 0; cursor: pointer; outline: none; transition: transform 0.2s ease; }
        .star-toggle-btn:hover { transform: scale(1.3) rotate(15deg); }

        .dropdown { position: relative; display: inline-flex; align-items: center; }
        .dropdown-btn {
            background: transparent; border: none; color: var(--text-muted); font-size: 1.5rem;
            cursor: pointer; font-weight: bold; padding: 5px 10px; transition: color 0.3s;
        }
        .dropdown:hover .dropdown-btn { color: white; }

        .dropdown-content {
            visibility: hidden; opacity: 0; position: absolute; right: 0; 
            top: 100%; margin-top: 5px; 
            background-color: rgba(28, 28, 38, 0.98); backdrop-filter: blur(12px);
            min-width: 210px; box-shadow: 0 15px 40px rgba(0,0,0,0.6);
            border: 1px solid var(--border-color); border-radius: 14px; overflow: hidden;
            padding: 8px 0; transition: all 0.2s ease-out; transform: translateY(10px); z-index: 99999;
        }

        .dropdown.drop-up .dropdown-content {
            top: auto; bottom: 100%; margin-top: 0; margin-bottom: 5px; transform: translateY(-10px);
        }

        .dropdown::after { content: ''; position: absolute; top: 100%; right: 0; width: 100%; height: 25px; background: transparent; }
        .dropdown.drop-up::after { top: auto; bottom: 100%; }

        .dropdown:hover .dropdown-content { visibility: visible; opacity: 1; transform: translateY(0); }

        .dropdown-content a, .dropdown-content .btn-delete {
            color: #E2E2E9; padding: 12px 18px; text-decoration: none; display: flex; align-items: center;
            gap: 12px; width: 100%; text-align: left; font-size: 0.9rem; font-weight: 500; background: transparent;
            border: none; cursor: pointer; transition: background 0.2s; white-space: nowrap; 
        }
        .dropdown-content a:hover, .dropdown-content .btn-delete:hover { background-color: rgba(107, 91, 255, 0.15); color: white; }
        .dropdown-content .btn-delete { color: #FF5C5C; }
        .dropdown-content .btn-delete:hover { background-color: rgba(255, 92, 92, 0.1); color: #FF7070; }

        .cat-dropdown-portal {
            display: none; position: fixed; background-color: rgba(28, 28, 38, 0.98); backdrop-filter: blur(12px);
            min-width: 160px; box-shadow: 0 15px 40px rgba(0,0,0,0.6); border: 1px solid var(--border-color);
            border-radius: 12px; overflow: hidden; padding: 5px 0; z-index: 999999 !important;
        }
        .cat-dropdown-portal.show { display: block; animation: fadeUp 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .cat-dropdown-portal a, .cat-dropdown-portal .btn-delete {
            color: #E2E2E9; padding: 10px 16px; text-decoration: none; display: flex; align-items: center; gap: 8px;
            width: 100%; text-align: left; font-size: 0.85rem; font-weight: 500; background: transparent; border: none; cursor: pointer; transition: 0.2s;
        }
        .cat-dropdown-portal a:hover, .cat-dropdown-portal .btn-delete:hover { background-color: rgba(107, 91, 255, 0.15); color: white; }
        .cat-dropdown-portal .btn-delete { color: #FF5C5C; }
        .cat-dropdown-portal .btn-delete:hover { background-color: rgba(255, 92, 92, 0.1); color: #FF7070; }

        .btn-empty-primary { display: inline-flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--accent), #8375FF); color: white; border: none; padding: 14px 32px; border-radius: 30px; font-weight: 600; font-size: 0.95rem; text-decoration: none; transition: all 0.3s; box-shadow: 0 4px 15px var(--accent-glow); }
        .btn-empty-primary:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(107, 91, 255, 0.4); }
        .btn-empty-secondary { display: inline-flex; align-items: center; justify-content: center; background: rgba(255, 255, 255, 0.05); color: var(--text-white); border: 1px solid var(--border-color); padding: 14px 32px; border-radius: 30px; font-weight: 600; font-size: 0.95rem; text-decoration: none; transition: all 0.3s; }
        .btn-empty-secondary:hover { background: #FFFFFF; color: #0F0F14; transform: translateY(-5px); }
    </style>
</head>
<body>

    <div class="app">
        <aside class="sidebar" id="mainSidebar">
            <div class="logo-row">
                <div class="logo-dot">📒</div>
                <span class="logo-name">Agenda</span>
            </div>

            <form class="search-side" asp-action="Index" method="get" onsubmit="return false;">
                <button type="submit" style="font-size:16px">⌕</button>
                <input type="text" id="liveSearchInput" name="searchString" placeholder="Buscar contacto..." value="@Context.Request.Query["searchString"]" autocomplete="off" />
            </form>

            <div class="sec-label">Vistas</div>
            <a asp-action="Index" class="nav-item @(string.IsNullOrEmpty(Context.Request.Query["soloFavoritos"]) && string.IsNullOrEmpty(Context.Request.Query["categoria"]) ? "active" : "")">
                <div class="nav-left"><span>👥</span><span class="nav-text">Todos</span></div>
                <span class="nav-count">@(ViewBag.TotalTodos ?? 0)</span>
            </a>
            <a asp-action="Index" asp-route-soloFavoritos="true" class="nav-item @(Context.Request.Query["soloFavoritos"] == "true" ? "active" : "")">
                <div class="nav-left"><span>⭐</span><span class="nav-text">Favoritos</span></div>
                <span class="nav-count">@(ViewBag.TotalFavoritos ?? 0)</span>
            </a>

            <div class="sec-label">Categorías</div>

            <a asp-controller="Categorias" asp-action="Crear" class="add-cat-btn">
                <span style="font-size: 1.1rem; line-height: 1;">+</span>
                <span>Añadir Categoría</span>
            </a>

            <div class="categories-container" id="catContainer">
                @if (ViewBag.CategoriasDinamicas != null)
                {
                    foreach (var cat in ViewBag.CategoriasDinamicas)
                    {
                        // OCULTAR CATEGORÍA GENERAL
                        if (cat.NombreCategoria == "General") continue;

                        <div class="cat-item-wrapper">
                            <a asp-action="Index" asp-route-categoria="@cat.NombreCategoria"
                               class="nav-item @(Context.Request.Query["categoria"] == cat.NombreCategoria ? "active" : "")">
                                <div class="nav-left">
                                    <span style="font-size: 1.1rem;">@(string.IsNullOrEmpty(cat.Emoji) ? "📁" : cat.Emoji)</span>
                                    <span class="nav-text">@cat.NombreCategoria</span>
                                </div>
                                <span class="nav-count">@cat.Count</span>
                            </a>

                            <div style="padding-right: 5px;">
                                <button class="dropdown-btn trigger-cat-menu">⋮</button>
                                <div class="cat-dropdown-portal">
                                    <a asp-controller="Categorias" asp-action="Detalles" asp-route-id="@cat.Id">👀 Ver Detalles</a>
                                    <a asp-controller="Categorias" asp-action="Editar" asp-route-id="@cat.Id">✏️ Editar</a>
                                    <a asp-controller="Categorias" asp-action="Eliminar" asp-route-id="@cat.Id" class="btn-delete">🗑️ Eliminar</a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="sidebar-footer">
                <a class="add-btn" asp-action="Crear">+ Nuevo contacto</a>
            </div>
        </aside>

        <main class="main" id="mainContent">
            <div class="topbar">
                <div class="title-wrapper">
                    <button id="toggleBtn" class="toggle-btn" title="Alternar Menú">
                        <span id="toggleIcon">◀</span>
                    </button>
                    <div class="page-title">
                        @(ViewData["FiltroActual"] != null ? ViewData["FiltroActual"] : "Agenda de Contactos")
                    </div>
                </div>
                <div class="tab-row">
                    <a asp-controller="Contactos" asp-action="Index" class="tab @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Todos</a>
                    <a asp-controller="Contactos" asp-action="Recientes" class="tab @(ViewContext.RouteData.Values["action"]?.ToString() == "Recientes" ? "active" : "")">Agregados Recientemente</a>
                    <a asp-controller="Contactos" asp-action="Ayuda" class="tab @(ViewContext.RouteData.Values["action"]?.ToString() == "Ayuda" ? "active" : "")">Ayuda</a>
                </div>
            </div>

            <div class="content">

                <div id="dynamicEmptyState" style="display: none; grid-column: 1 / -1; text-align: center; padding: 80px 20px; background: rgba(28, 28, 38, 0.4); border-radius: 20px; border: 1px dashed rgba(107, 91, 255, 0.3); backdrop-filter: blur(8px);">
                    <div style="font-size: 5rem; margin-bottom: 25px; opacity: 0.9; display: inline-block;">🔍</div>
                    <h3 style="color: var(--text-white); font-size: 2rem; font-weight: 700; margin-bottom: 10px;">No hay resultados</h3>
                    <p style="color: var(--text-muted); font-size: 1.1rem; max-width: 420px; margin: 0 auto;">No coincide ningún contacto con tu búsqueda actual.</p>
                </div>

                @if (!Model.Any())
                {
                    <div class="empty-state" style="grid-column: 1 / -1; text-align: center; padding: 80px 20px; background: rgba(28, 28, 38, 0.4); border-radius: 20px; border: 1px dashed rgba(107, 91, 255, 0.3); animation: fadeUp 0.5s ease-out forwards; backdrop-filter: blur(8px); position: relative; overflow: hidden;">
                        <div style="position: absolute; width: 300px; height: 300px; background: var(--accent); opacity: 0.05; filter: blur(80px); top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 50%; pointer-events: none;"></div>
                        <div style="font-size: 5rem; margin-bottom: 25px; opacity: 0.9; text-shadow: 0 15px 30px rgba(0,0,0,0.4); display: inline-block; animation: floatIcon 4s ease-in-out infinite; position: relative; z-index: 2;">📭</div>
                        <h3 style="color: var(--text-white); font-family: 'DM Sans', sans-serif; font-size: 2rem; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 12px; position: relative; z-index: 2;">No hay contactos aquí</h3>
                        <p style="color: var(--text-muted); font-size: 1.1rem; max-width: 450px; margin: 0 auto 35px auto; line-height: 1.6; position: relative; z-index: 2;">No encontramos ningún contacto en esta categoría o búsqueda. Puedes intentar buscar otra cosa o volver al inicio.</p>
                        <div style="display: flex; gap: 20px; justify-content: center; position: relative; z-index: 2;">
                            <a asp-action="Crear" class="btn-empty-primary">+ Nuevo Contacto</a>
                            <a asp-action="Index" class="btn-empty-secondary">Mostrar Todos</a>
                        </div>
                    </div>
                }
                else
                {
                    var favoritos = Model.Where(c => c.EsFavorito).ToList();
                    var otros = Model.Where(c => !c.EsFavorito).ToList();

                    if (favoritos.Any())
                    {
                        var favGradients = new[] { "linear-gradient(135deg, #6366f1, #a855f7)", "linear-gradient(135deg, #3b82f6, #2dd4bf)", "linear-gradient(135deg, #f43f5e, #fb923c)", "linear-gradient(135deg, #22c55e, #84cc16)", "linear-gradient(135deg, #8b5cf6, #d946ef)", "linear-gradient(135deg, #f59e0b, #eab308)" };
                        int countFav = 0;

                        <div class="grid-label section-label-fav">Contactos Favoritos</div>
                        <div class="contacts-grid section-grid-fav">
                            @foreach (var item in favoritos)
                            {
                                var grad = favGradients[countFav % 6]; countFav++;
                                <div class="fav-card contact-item-card">
                                    <div class="avatar-box" style="background: @grad; color: white; box-shadow: 0 6px 15px rgba(0,0,0,0.3);">@(string.IsNullOrEmpty(item.Nombre) ? "?" : item.Nombre.Substring(0, 1).ToUpper())</div>
                                    <div class="fav-info">
                                        <div class="fav-name searchable-name" title="@item.Nombre @item.Apellido">@item.Nombre @item.Apellido</div>
                                        <div class="fav-detail searchable-phone">@item.Telefono</div>
                                    </div>
                                    <div style="display: flex; align-items: center; flex-shrink: 0;">
                                        @if (nuevosIds.Contains(item.Id))
                                        {
                                            <span class="badge-nuevo">Nuevo</span>
                                        }
                                        <form asp-action="ToggleFavorito" asp-route-id="@item.Id" method="post" style="margin-right: 12px;">
                                            <button type="submit" class="star-toggle-btn"><span style="color: #FBBF24; font-size: 1.4rem;">★</span></button>
                                        </form>
                                        
                                        <div class="dropdown">
                                            <button class="dropdown-btn">⋮</button>
                                            <div class="dropdown-content">
                                                <a asp-action="Detalles" asp-route-id="@item.Id">👀 Ver Detalles</a>
                                                <a asp-action="Editar" asp-route-id="@item.Id">✏️ Editar</a>
                                                <a asp-action="Eliminar" asp-route-id="@item.Id" class="btn-delete">🗑️ Eliminar</a>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>
                    }

                    if (otros.Any())
                    {
                        var neonPalette = new (string Bg, string Text)[] { ("rgba(99, 102, 241, 0.12)", "#818cf8"), ("rgba(16, 185, 129, 0.12)", "#34d399"), ("rgba(244, 63, 94, 0.12)", "#fb7185"), ("rgba(234, 179, 8, 0.12)", "#facc15"), ("rgba(168, 85, 247, 0.12)", "#c084fc"), ("rgba(6, 182, 212, 0.12)", "#22d3ee") };
                        int countOtros = 0;

                        <div class="grid-label section-label-others" style="animation-delay: 0.2s;">Otros Contactos</div>
                        <div class="contacts-grid section-grid-others">
                            @foreach (var contact in otros)
                            {
                                var style = neonPalette[countOtros % 6]; countOtros++;
                                <div class="c-card contact-item-card">
                                    <div class="avatar-box" style="background-color: @style.Bg; border: 1.5px solid @style.Text; color: @style.Text;">@(string.IsNullOrEmpty(contact.Nombre) ? "?" : contact.Nombre.Substring(0, 1).ToUpper())</div>
                                    <div class="c-info">
                                        <div class="c-name searchable-name" title="@contact.Nombre @contact.Apellido">@contact.Nombre @contact.Apellido</div>
                                        <div class="c-phone searchable-phone">@contact.Telefono</div>
                                    </div>
                                    <div style="display: flex; align-items: center; flex-shrink: 0;">
                                        @if (nuevosIds.Contains(contact.Id))
                                        {
                                            <span class="badge-nuevo">Nuevo</span>
                                        }
                                        <form asp-action="ToggleFavorito" asp-route-id="@contact.Id" method="post" style="margin-right: 12px;">
                                            <button type="submit" class="star-toggle-btn"><span style="color: #4A4A63; font-size: 1.4rem;">★</span></button>
                                        </form>

                                        <div class="dropdown">
                                            <button class="dropdown-btn">⋮</button>
                                            <div class="dropdown-content">
                                                <a asp-action="Detalles" asp-route-id="@contact.Id">👀 Ver Detalles</a>
                                                <a asp-action="Editar" asp-route-id="@contact.Id">✏️ Editar</a>
                                                <a asp-action="Eliminar" asp-route-id="@contact.Id" class="btn-delete">🗑️ Eliminar</a>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('mainSidebar');
            const mainContent = document.getElementById('mainContent');
            const toggleBtn = document.getElementById('toggleBtn');
            const toggleIcon = document.getElementById('toggleIcon');

            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('expanded');
                toggleIcon.textContent = sidebar.classList.contains('collapsed') ? '▶' : '◀';
            });

            const catMenus = document.querySelectorAll('.cat-dropdown-portal');
            catMenus.forEach(menu => document.body.appendChild(menu));

            const triggerBtns = document.querySelectorAll('.trigger-cat-menu');
            triggerBtns.forEach((btn, index) => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    e.preventDefault();
                    document.querySelectorAll('.cat-dropdown-portal.show').forEach(m => m.classList.remove('show'));
                    const menu = catMenus[index];
                    const rect = btn.getBoundingClientRect();
                    menu.style.top = `${rect.top - 10}px`;
                    menu.style.left = `${rect.right + 15}px`;
                    menu.classList.add('show');
                });
            });

            document.getElementById('catContainer').addEventListener('scroll', () => {
                document.querySelectorAll('.cat-dropdown-portal.show').forEach(m => m.classList.remove('show'));
            });

            document.addEventListener('click', (e) => {
                document.querySelectorAll('.cat-dropdown-portal.show').forEach(m => {
                    if(!m.contains(e.target)) m.classList.remove('show');
                });
            });

            const dropdowns = document.querySelectorAll('.dropdown');
            dropdowns.forEach(dropdown => {
                dropdown.addEventListener('mouseenter', function() {
                    const rect = this.getBoundingClientRect();
                    if (window.innerHeight - rect.bottom < 220) {
                        this.classList.add('drop-up');
                    } else {
                        this.classList.remove('drop-up');
                    }
                });
            });

            const searchInput = document.getElementById('liveSearchInput');
            const cards = document.querySelectorAll('.contact-item-card');
            const emptyState = document.getElementById('dynamicEmptyState');

            const labelFav = document.querySelector('.section-label-fav');
            const gridFav = document.querySelector('.section-grid-fav');
            const labelOthers = document.querySelector('.section-label-others');
            const gridOthers = document.querySelector('.section-grid-others');

            searchInput.addEventListener('input', function() {
                const query = this.value.toLowerCase().trim();
                let visibleCount = 0;
                let visibleFav = 0;
                let visibleOthers = 0;

                cards.forEach(card => {
                    const name = card.querySelector('.searchable-name').textContent.toLowerCase();
                    const phone = card.querySelector('.searchable-phone').textContent.toLowerCase();

                    if (name.includes(query) || phone.includes(query)) {
                        card.style.display = ""; 
                        visibleCount++;
                        if (card.classList.contains('fav-card')) visibleFav++;
                        else visibleOthers++;
                    } else {
                        card.style.display = "none"; 
                    }
                });

                if (labelFav) labelFav.style.display = (visibleFav > 0) ? "" : "none";
                if (gridFav) gridFav.style.display = (visibleFav > 0) ? "" : "none";
                if (labelOthers) labelOthers.style.display = (visibleOthers > 0) ? "" : "none";
                if (gridOthers) gridOthers.style.display = (visibleOthers > 0) ? "" : "none";

                if (visibleCount === 0 && query !== "") emptyState.style.display = "block";
                else emptyState.style.display = "none";
            });
        });
    </script>
</body>
</html>