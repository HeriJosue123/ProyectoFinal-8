@model IEnumerable<ContactManagerWeb.Models.Contacto>

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agenda — Contact Manager Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-sidebar: #0F0F14;
            --bg-main: #171721;
            --bg-card: #20202B;
            --text-white: #FFFFFF;
            --text-muted: #8A8A9E;
            --border-color: #2D2D3D;
            --accent: #5A4FCF;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; }
        body { background-color: var(--bg-main); color: var(--text-white); height: 100vh; overflow: hidden; }
        button, input { font-family: 'DM Sans', sans-serif; }

        .app { display: flex; height: 100%; width: 100%; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        /* SIDEBAR */
        .sidebar { width: 280px; background-color: var(--bg-sidebar); border-right: 1px solid var(--border-color); display: flex; flex-direction: column; padding: 25px 20px; animation: slideInLeft 0.5s ease-out forwards; }
        .logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 25px; }
        .logo-dot { background: linear-gradient(135deg, #9D88FF, #6B5BFF); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: transform 0.3s; }
        .logo-row:hover .logo-dot { transform: rotate(10deg) scale(1.1); }
        .logo-name { font-weight: 700; font-size: 1.1rem; letter-spacing: 0.5px; }
        
        .search-side { background-color: #1C1C26; border: 1px solid var(--border-color); border-radius: 10px; padding: 10px 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 30px; transition: 0.3s; }
        .search-side:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(90, 79, 207, 0.2); }
        .search-side input { background: transparent; border: none; color: white; width: 100%; outline: none; }
        
        .sec-label { font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin: 20px 0 10px 5px; }
        
        .nav-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; border-radius: 8px; color: var(--text-muted); text-decoration: none; transition: all 0.3s ease; margin-bottom: 5px; }
        .nav-item:hover, .nav-item.active { background-color: #2A254D; color: white; transform: translateX(5px); }
        .nav-left { display: flex; align-items: center; gap: 12px; font-weight: 500; }
        .nav-count { background-color: #1C1C26; font-size: 0.75rem; padding: 2px 8px; border-radius: 10px; font-weight: 600; }
        
        .sidebar-footer { margin-top: auto; }
        .add-btn { display: block; text-align: center; border: 1px solid var(--border-color); color: white; text-decoration: none; padding: 12px; border-radius: 20px; font-weight: 600; transition: all 0.3s ease; }
        .add-btn:hover { background-color: var(--accent); border-color: var(--accent); transform: translateY(-3px); box-shadow: 0 5px 15px rgba(90, 79, 207, 0.4); }

        /* MAIN */
        .main { flex: 1; display: flex; flex-direction: column; overflow-y: auto; padding: 40px 60px; scroll-behavior: smooth; }
        
        .topbar { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 20px; margin-bottom: 30px; animation: fadeUp 0.5s ease-out forwards; }
        .page-title { font-family: 'DM Serif Display', serif; font-size: 2.2rem; }
        .tab-row { display: flex; gap: 20px; }
        .tab { color: var(--text-muted); text-decoration: none; font-weight: 500; transition: 0.2s; position: relative; }
        .tab.active { color: white; }
        .tab.active::after { content: ''; position: absolute; bottom: -22px; left: 0; width: 100%; height: 2px; background-color: var(--accent); border-radius: 2px; }
        .tab:hover { color: white; }

        .grid-label { font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; animation: fadeUp 0.5s ease-out forwards; }
        .contacts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 15px; margin-bottom: 30px; }
        
        .fav-card { background: linear-gradient(135deg, #2D2554 0%, var(--bg-card) 100%); border: 1px solid #4B3F85; border-radius: 12px; padding: 15px 20px; display: flex; align-items: center; gap: 15px; box-shadow: 0 8px 20px rgba(0,0,0,0.15); transition: all 0.3s ease; opacity: 0; animation: fadeUp 0.6s ease-out forwards; }
        .fav-card:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 12px 25px rgba(0,0,0,0.3); border-color: #6B5BFF; }
        .fav-avatar { width: 45px; height: 45px; border-radius: 50%; background: linear-gradient(135deg, #FF66C4, #A653FF); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: 700; border: 2px solid #3E346B; }
        .fav-info { flex: 1; }
        .fav-name { font-size: 1rem; font-weight: 600; margin-bottom: 2px; }
        .fav-detail { color: #B4B4C7; font-size: 0.85rem; }
        
        .act-btn { background: transparent; border: none; color: var(--text-muted); font-size: 1.1rem; cursor: pointer; transition: all 0.2s; }
        .act-btn:hover { color: white; transform: scale(1.2); }
        .act-btn.star { color: #FBBF24; }

        .c-card { background-color: var(--bg-card); border: 1px solid var(--border-color); border-radius: 12px; padding: 15px 20px; display: flex; align-items: center; gap: 15px; transition: all 0.3s ease; opacity: 0; animation: fadeUp 0.6s ease-out forwards; }
        .c-card:hover { border-color: #4A4A63; transform: translateY(-4px) scale(1.02); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
        .sm-avatar { width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; color: white; transition: transform 0.3s; }
        .c-card:hover .sm-avatar { transform: rotate(-10deg); }
        .c-info { flex: 1; }
        .c-name { font-weight: 600; margin-bottom: 2px; font-size: 1rem; }
        .c-phone { color: var(--text-muted); font-size: 0.85rem; }
        .c-star { background: transparent; border: none; color: var(--text-muted); font-size: 1.2rem; cursor: pointer; transition: all 0.2s; }
        .c-star:hover { color: #FBBF24; transform: scale(1.2); }
    </style>
</head>
<body>

<div class="app">
    <aside class="sidebar">
        <div class="logo-row">
            <div class="logo-dot">📒</div>
            <span class="logo-name">Agenda</span>
        </div>
        <div class="search-side">
            <span style="font-size:15px">⌕</span>
            <input type="text" placeholder="Buscar..." />
        </div>

        <div class="sec-label">Vistas</div>
        <a href="#" class="nav-item active">
            <div class="nav-left"><span>👥</span><span class="nav-text">Todos</span></div>
            <span class="nav-count">@Model.Count()</span>
        </a>
        <a href="#" class="nav-item">
            <div class="nav-left"><span>⭐</span><span class="nav-text">Favoritos</span></div>
            <span class="nav-count">@Model.Count(c => c.EsFavorito)</span>
        </a>

        <div class="sec-label">Categorías</div>
        <a href="#" class="nav-item">
            <div class="nav-left"><span>💼</span><span class="nav-text">Trabajo</span></div>
            <span class="nav-count">@Model.Count(c => c.Categoria == "Trabajo")</span>
        </a>
        <a href="#" class="nav-item">
            <div class="nav-left"><span>🤝</span><span class="nav-text">Amigos</span></div>
            <span class="nav-count">@Model.Count(c => c.Categoria == "Amigos")</span>
        </a>
        <a href="#" class="nav-item">
            <div class="nav-left"><span>🏡</span><span class="nav-text">Familia</span></div>
            <span class="nav-count">@Model.Count(c => c.Categoria == "Familia")</span>
        </a>

        <div class="sidebar-footer">
            <a class="add-btn" asp-action="Crear">+ Nuevo contacto</a>
        </div>
    </aside>

    <main class="main">
        <div class="topbar">
            <div class="page-title">Contactos</div>
            <div class="tab-row">
                <a href="#" class="tab active">Todos</a>
                <a href="#" class="tab">Recientes</a>
                <a href="#" class="tab">Favoritos</a>
            </div>
        </div>

        <div class="content">
            @* Lógica para buscar el favorito destacado *@
            @{ 
                var fav = Model.OrderByDescending(c => c.EsFavorito).FirstOrDefault(); 
            }
            
            @if (fav != null)
            {
                <div class="grid-label">Favorito Destacado</div>
                <div class="contacts-grid">
                    <div class="fav-card">
                        <div class="fav-avatar">
                            @(fav.Nombre.Length >= 2 ? fav.Nombre.Substring(0, 2).ToUpper() : fav.Nombre.ToUpper())
                        </div>
                        <div class="fav-info">
                            <div class="fav-name">@fav.Nombre</div>
                            <div class="fav-detail">
                                <span>@fav.Telefono</span>
                            </div>
                        </div>
                        <div style="display: flex; gap: 8px;">
                            <button class="act-btn star">★</button>
                            <button class="act-btn">✎</button>
                        </div>
                    </div>
                </div>
            }


            <div class="grid-label" style="animation-delay: 0.2s;">Todos los contactos</div>
            <div class="contacts-grid">
                @foreach (var contact in Model.Where(c => c != fav))
                {
                    <div class="c-card">
                        @{ 
                            var colors = new[] { "#295A76", "#8B3E56", "#7A5C29", "#1C5248", "#334166" }; 
                            var color = colors[Math.Abs(contact.Nombre.GetHashCode()) % colors.Length]; 
                        }
                        <div class="sm-avatar" style="background-color: @color;">
                            @(contact.Nombre.Length >= 2 ? contact.Nombre.Substring(0, 2).ToUpper() : contact.Nombre.ToUpper())
                        </div>
                        <div class="c-info">
                            <div class="c-name">@contact.Nombre</div>
                            <div class="c-phone">@contact.Telefono</div>
                        </div>
                        @if(contact.EsFavorito) {
                            <button class="c-star" style="color: #FBBF24;">★</button>
                        } else {
                            <button class="c-star">☆</button>
                        }
                    </div>
                }
            </div>
        </div>
    </main>
</div>
</body>
</html>