    <script>
        function toggleEmojiDropdown() {
            document.getElementById('emojiDropdown').classList.toggle('active');
        }

        function selectEmoji(emoji, text) {
            document.getElementById('hiddenEmoji').value = emoji;
            document.getElementById('displayEmoji').innerText = emoji;
            document.getElementById('displayText').innerText = text;
            toggleEmojiDropdown();
        }

        // Cerrar el dropdown al hacer click afuera
        window.onclick = function(event) {
            if (!event.target.closest('.custom-emoji-picker')) {
                document.getElementById('emojiDropdown').classList.remove('active');
            }
        }
    </script>
