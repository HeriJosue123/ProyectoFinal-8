@model ContactManagerWeb.Models.Categoria
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Categoría — Agenda</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: #171721;
            --bg-input: #1C1C26;
            --accent: #5A4FCF;
            --text-muted: #8A8A9E;
            --border: rgba(255, 255, 255, 0.08);
            --danger: #FF5555;
        }

        body { 
            background-color: var(--bg-body); 
            color: #FFF; 
            font-family: 'DM Sans', sans-serif; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh; 
            margin: 0; 
            padding: 40px 20px 150px 20px;
            box-sizing: border-box;
        }

        @@keyframes scaleIn {
            from { opacity: 0; transform: scale(0.9) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .card { 
            background: var(--bg-card); 
            padding: 40px; 
            border-radius: 28px; 
            border: 1px solid var(--border); 
            width: 100%; 
            max-width: 420px; 
            box-shadow: 0 25px 60px rgba(0,0,0,0.6); 
            animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        h2 { 
            text-align: center; 
            margin-bottom: 35px; 
            font-weight: 700; 
            letter-spacing: -1px; 
            font-size: 1.8rem; 
        }
        h2 span {
            display: block;
            font-size: 2.2rem;
            margin-bottom: 8px;
            filter: drop-shadow(0 5px 10px rgba(0,0,0,0.4));
        }

        .form-group { margin-bottom: 25px; position: relative; }
        label { display: block; margin-bottom: 10px; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; font-weight: 700; letter-spacing: 1px; }
        
        .dark-input { 
            width: 100%; padding: 14px 18px; border-radius: 14px; border: 1px solid var(--border); 
            background: var(--bg-input); color: white; outline: none; transition: 0.3s; box-sizing: border-box; font-size: 1rem;
        }
        .dark-input:focus { border-color: var(--accent); box-shadow: 0 0 0 4px rgba(90, 79, 207, 0.15); }

        .text-danger { color: var(--danger); font-size: 0.75rem; margin-top: 6px; display: block; }

        .custom-emoji-picker { position: relative; user-select: none; }
        .emoji-trigger { display: flex; align-items: center; justify-content: space-between; cursor: pointer; }
        .emoji-trigger .current { display: flex; align-items: center; gap: 12px; }

        /* Despliegue hacia ABAJO */
        .emoji-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            left: 0;
            width: 100%;
            background: #1C1C26;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 15px;
            z-index: 1000;
            display: none;
            box-shadow: 0 15px 40px rgba(0,0,0,0.4);
            backdrop-filter: blur(10px);
            max-height: 350px;
            overflow-y: auto;
        }

        .emoji-dropdown.active { display: block; animation: scaleIn 0.2s ease-out; }

        .emoji-section-title {
            font-size: 0.7rem;
            color: var(--accent);
            margin: 18px 0 10px 5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 800;
        }
        .emoji-section-title:first-child { margin-top: 5px; }

        /* MAGIA RESPONSIVA: Se adapta solo dependiendo del ancho */
        .emoji-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(40px, 1fr)); gap: 6px; }

        .emoji-item {
            aspect-ratio: 1;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; border-radius: 10px; cursor: pointer; transition: 0.2s;
        }
        .emoji-item:hover { background: rgba(255, 255, 255, 0.08); transform: scale(1.25); z-index: 2; position: relative;}

        .emoji-dropdown::-webkit-scrollbar { width: 6px; }
        .emoji-dropdown::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }
        .emoji-dropdown::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        .btn-save { 
            width: 100%; padding: 16px; background: var(--accent); color: white; border: none; 
            border-radius: 15px; cursor: pointer; transition: 0.3s; margin-top: 15px; 
            font-size: 1rem;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .btn-save:hover { background: #6B5BFF; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(90, 79, 207, 0.3); }
        
        .btn-back { 
            display: block; text-align: center; margin-top: 25px; color: var(--text-muted); text-decoration: none; 
            font-size: 0.9rem; transition: 0.3s; 
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
        }
        .btn-back:hover { color: white; }

        .validation-summary-errors {
            background: rgba(255, 85, 85, 0.1);
            border: 1px solid rgba(255, 85, 85, 0.3);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 20px;
        }
        .validation-summary-errors ul { list-style: none; padding: 0; margin: 0; }
        .validation-summary-errors li { color: var(--danger); font-size: 0.85rem; font-weight: 500; text-align: center; }
    </style>
</head>
