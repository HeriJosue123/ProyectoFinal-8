@model ContactManagerWeb.Models.Categoria
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Categoría — Agenda Web</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: #171721;
            --bg-input: #1C1C26;
            --accent: #6B5BFF;
            --accent-hover: #8375FF;
            --text-muted: #8A8A9E;
            --border: rgba(255, 255, 255, 0.08);
            --danger: #FF5555;
            --shadow-color: rgba(0, 0, 0, 0.6);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; }

        body { 
            background-color: var(--bg-body); 
            background-image: radial-gradient(circle at 50% 0%, rgba(107, 91, 255, 0.05), transparent 50%);
            color: #FFF; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh; 
            padding: 40px 20px;
            overflow-x: hidden;
        }

        /* --- Animaciones --- */
        @@keyframes scaleIn {
            from { opacity: 0; transform: scale(0.95) translateY(20px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        @@keyframes itemReveal {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Tarjeta Principal */
        .card { 
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 40px; 
            border-radius: 24px; 
            border: 1px solid var(--border); 
            width: 100%; 
            max-width: 450px; 
            box-shadow: 0 25px 60px var(--shadow-color), inset 0 1px 0 rgba(255,255,255,0.05); 
            animation: scaleIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            opacity: 0;
        }

        /* Stagger para los elementos hijos */
        .header-content { opacity: 0; animation: itemReveal 0.5s ease-out 0.1s forwards; text-align: center; margin-bottom: 35px; }
        .stagger-1 { opacity: 0; animation: itemReveal 0.5s ease-out 0.2s forwards; }
        .stagger-2 { opacity: 0; animation: itemReveal 0.5s ease-out 0.3s forwards; }
        .stagger-3 { opacity: 0; animation: itemReveal 0.5s ease-out 0.4s forwards; }
        .stagger-4 { opacity: 0; animation: itemReveal 0.5s ease-out 0.5s forwards; }

        .header-emoji {
            display: inline-block;
            background: linear-gradient(135deg, rgba(107, 91, 255, 0.2), rgba(163, 150, 255, 0.1));
            width: 60px; height: 60px;
            border-radius: 16px;
            font-size: 2rem;
            line-height: 60px;
            margin-bottom: 15px;
            border: 1px solid rgba(107, 91, 255, 0.3);
            box-shadow: 0 8px 20px rgba(107, 91, 255, 0.2);
        }

        h2 { 
            font-family: 'DM Serif Display', serif;
            font-size: 2rem; 
            letter-spacing: -0.5px;
            margin-bottom: 5px;
        }

        .header-subtitle { color: var(--text-muted); font-size: 0.95rem; }

        /* Campos del Formulario */
        .form-group { margin-bottom: 22px; position: relative; }
        
        label { 
            display: block; margin-bottom: 8px; color: var(--text-muted); 
            font-size: 0.75rem; text-transform: uppercase; font-weight: 700; letter-spacing: 1px; 
        }
        
        .dark-input { 
            width: 100%; padding: 14px 16px; border-radius: 12px; border: 1px solid var(--border); 
            background: var(--bg-input); color: white; outline: none; transition: 0.3s ease; 
            font-size: 0.95rem; box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);
        }
        
        .dark-input:focus { 
            border-color: var(--accent); 
            background: rgba(28, 28, 38, 0.8);
            box-shadow: 0 0 0 4px rgba(107, 91, 255, 0.15), inset 0 2px 4px rgba(0,0,0,0.2); 
        }
        
        textarea.dark-input { resize: vertical; min-height: 80px; }

        .text-danger { color: var(--danger); font-size: 0.75rem; margin-top: 6px; display: block; font-weight: 500; }

        /* Selector de Emojis */
        .custom-emoji-picker { position: relative; user-select: none; }
        
        .emoji-trigger { 
            display: flex; align-items: center; justify-content: space-between; cursor: pointer; 
            background: var(--bg-input); border: 1px solid var(--border); border-radius: 12px;
            padding: 12px 16px; transition: all 0.3s ease;
        }
        .emoji-trigger:hover { border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.02); }
        
        .emoji-trigger .current { display: flex; align-items: center; gap: 12px; font-weight: 500;}
        .emoji-trigger .current-emoji { font-size: 1.4rem; line-height: 1;}

        .emoji-dropdown {
            position: absolute; top: calc(100% + 8px); left: 0; width: 100%;
            background: rgba(20, 20, 28, 0.95); border: 1px solid var(--border); border-radius: 16px;
            padding: 12px; z-index: 1000; display: none;
            box-shadow: 0 15px 40px rgba(0,0,0,0.5); backdrop-filter: blur(15px);
            max-height: 280px; overflow-y: auto;
        }
        .emoji-dropdown.active { display: block; animation: itemReveal 0.2s ease-out; }

        .emoji-section-title {
            font-size: 0.65rem; color: #A396FF; margin: 15px 0 8px 5px; 
            text-transform: uppercase; letter-spacing: 0.5px; font-weight: 800;
        }
        .emoji-section-title:first-child { margin-top: 0; }

        .emoji-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(40px, 1fr)); gap: 4px; }

        .emoji-item {
            aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; border-radius: 10px; cursor: pointer; transition: 0.2s;
        }
        .emoji-item:hover { background: rgba(107, 91, 255, 0.2); transform: scale(1.15); z-index: 2; position: relative; }

        .emoji-dropdown::-webkit-scrollbar { width: 5px; }
        .emoji-dropdown::-webkit-scrollbar-thumb { background: #3E3E54; border-radius: 10px; }
        .emoji-dropdown::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        /* Botones */
        .btn-save { 
            width: 100%; padding: 14px; background: linear-gradient(135deg, var(--accent), #8375FF); 
            color: white; border: none; border-radius: 12px; cursor: pointer; transition: all 0.3s ease; 
            margin-top: 10px; font-size: 1rem; font-weight: 700; letter-spacing: -0.3px;
            box-shadow: 0 8px 20px rgba(107, 91, 255, 0.25);
        }
        .btn-save:hover { transform: translateY(-2px); box-shadow: 0 12px 25px rgba(107, 91, 255, 0.4); filter: brightness(1.1); }
        
        .btn-back { 
            display: block; text-align: center; margin-top: 20px; color: var(--text-muted); text-decoration: none; 
            font-size: 0.9rem; transition: 0.3s; font-weight: 600;
        }
        .btn-back:hover { color: white; text-shadow: 0 0 10px rgba(255,255,255,0.3); }

        .validation-summary-errors {
            background: rgba(255, 85, 85, 0.1); border: 1px solid rgba(255, 85, 85, 0.2);
            border-radius: 12px; padding: 12px; margin-bottom: 20px;
        }
        .validation-summary-errors ul { list-style: none; padding: 0; margin: 0; }
        .validation-summary-errors li { color: var(--danger); font-size: 0.85rem; font-weight: 500; text-align: center; }

        @@media (max-width: 480px) {
            .card { padding: 30px 20px; border-radius: 20px; }
            h2 { font-size: 1.8rem; }
        }
    </style>
</head>
