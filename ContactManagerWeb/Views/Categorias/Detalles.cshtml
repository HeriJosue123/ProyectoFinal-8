@model ContactManagerWeb.Models.Categoria
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalles de Categoría — @Model.NombreCategoria</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    
    <style>
        :root {
            --bg-body: #0F0F14;
            --bg-card: rgba(23, 23, 33, 0.7);
            --box-bg: rgba(28, 28, 38, 0.6);
            --accent: #6B5BFF;
            --text-muted: #8A8A9E;
            --border: rgba(255, 255, 255, 0.08);
            --shadow-color: rgba(0, 0, 0, 0.6);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; }

        body {
            background-color: var(--bg-body);
            background-image: radial-gradient(circle at 50% 0%, rgba(107, 91, 255, 0.05), transparent 50%);
            color: #FFF;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            padding: 15px;
            overflow: hidden; /* Evita scroll */
        }

        /* --- ANIMACIONES --- */
        @@keyframes cardReveal {
            from { opacity: 0; transform: translateY(20px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        @@keyframes itemReveal {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Tarjeta Glassmorphism */
        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 35px 30px;
            border-radius: 24px;
            border: 1px solid var(--border);
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 50px var(--shadow-color), inset 0 1px 0 rgba(255,255,255,0.05);
            text-align: center;
            opacity: 0;
            animation: cardReveal 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        /* Efecto Cascada */
        .stagger-1 { opacity: 0; animation: itemReveal 0.4s ease-out 0.1s forwards; }
        .stagger-2 { opacity: 0; animation: itemReveal 0.4s ease-out 0.2s forwards; }
        .stagger-3 { opacity: 0; animation: itemReveal 0.4s ease-out 0.3s forwards; }
        .stagger-4 { opacity: 0; animation: itemReveal 0.4s ease-out 0.4s forwards; }

        /* Emoji Premium */
        .emoji-container {
            width: 85px;
            height: 85px;
            background: linear-gradient(135deg, rgba(107, 91, 255, 0.15), rgba(163, 150, 255, 0.05));
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px auto;
            font-size: 3rem;
            line-height: 1;
            border: 1px solid rgba(107, 91, 255, 0.25);
            box-shadow: 0 10px 25px rgba(107, 91, 255, 0.15), inset 0 4px 15px rgba(255,255,255,0.05);
        }

        .category-name {
            margin: 0 0 8px 0;
            font-family: 'DM Serif Display', serif;
            font-size: 2.2rem;
            letter-spacing: -0.5px;
            color: #FFF;
        }
        
        .category-badge {
            display: inline-block;
            background: rgba(107, 91, 255, 0.15);
            color: #A396FF;
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 25px;
            border: 1px dashed rgba(107, 91, 255, 0.3);
        }

        .info-group {
            text-align: left;
            margin-bottom: 25px;
        }

        .info-group label {
            display: block;
            color: var(--text-muted);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 6px;
            font-weight: 800;
        }

        .desc-box {
            background: var(--box-bg);
            border: 1px solid var(--border);
            color: #E2E2E9;
            padding: 15px;
            border-radius: 12px;
            font-size: 0.9rem;
            line-height: 1.5;
            min-height: 70px;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.2);
        }

        .empty-desc {
            color: #66667A;
            font-style: italic;
        }

        /* Botones */
        .btn-edit {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, var(--accent), #8375FF);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 700;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(107, 91, 255, 0.25);
            border: none;
        }

        .btn-edit:hover {
            transform: translateY(-2px); 
            box-shadow: 0 12px 25px rgba(107, 91, 255, 0.4); 
            filter: brightness(1.1);
        }
        
        .btn-back {
            display: block;
            margin-top: 15px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            transition: 0.3s ease;
        }

        .btn-back:hover {
            color: #FFF;
            text-shadow: 0 0 10px rgba(255,255,255,0.3);
        }

        @@media (max-width: 480px) {
            .glass-card { padding: 25px 20px; border-radius: 20px; }
            .emoji-container { width: 70px; height: 70px; font-size: 2.5rem; }
            .category-name { font-size: 1.8rem; }
        }
    </style>
</head>
<body>
    <div class="glass-card">
        
        <div class="stagger-1">
            <div class="emoji-container">
                @(string.IsNullOrEmpty(Model.Emoji) ? "📁" : Model.Emoji)
            </div>
            <h2 class="category-name">@Model.NombreCategoria</h2>
            <div class="category-badge">Categoría</div>
        </div>

        <div class="info-group stagger-2">
            <label>Descripción</label>
            <div class="desc-box">
                @if (!string.IsNullOrEmpty(Model.Descripcion))
                {
                    @Model.Descripcion
                }
                else
                {
                    <span class="empty-desc">No hay descripción para esta categoría.</span>
                }
            </div>
        </div>

        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn-edit stagger-3">
            <span>✏️</span> Editar Categoría
        </a>
        
        <a asp-controller="Categorias" asp-action="Index" class="btn-back stagger-4">Volver a Categorías</a>
    </div>
</body>
</html>