@model ContactManagerWeb.Models.Categoria
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalles de Categoría — @Model.NombreCategoria</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
            :root {
                --bg-body: #0F0F14;
                --bg-card: #16161E;
                --box-bg: #1C1C24;
                --primary: #5B4EFC;
                --primary-hover: #4A3EE0;
                --text-muted: #8A8A9E;
                --border: rgba(255, 255, 255, 0.05);
            }

            body {
                background-color: var(--bg-body);
                color: #FFF;
                font-family: 'DM Sans', sans-serif;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                margin: 0;
                padding: 20px;
            }

            .card {
                background: var(--bg-card);
                padding: 40px;
                border-radius: 24px;
                border: 1px solid var(--border);
                width: 100%;
                max-width: 400px;
                box-shadow: 0 20px 40px rgba(0,0,0,0.5);
                text-align: center;
            }

            .emoji-container {
                width: 100px;
                height: 100px;
                background: rgba(255, 255, 255, 0.03);
                border-radius: 30px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px auto;
                font-size: 3.5rem;
                border: 1px solid var(--border);
                box-shadow: inset 0 4px 20px rgba(0,0,0,0.2);
            }

            .category-name {
                margin: 0 0 5px 0;
                font-weight: 700;
                font-size: 2rem;
                color: #FFF;
            }
        
            .category-badge {
                display: inline-block;
                background: rgba(91, 78, 252, 0.15);
                color: #8C82FC;
                padding: 6px 12px;
                border-radius: 8px;
                font-size: 0.8rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 25px;
            }

            .info-group {
                text-align: left;
                margin-bottom: 25px;
            }

                .info-group label {
                    display: block;
                    color: var(--text-muted);
                    font-size: 0.75rem;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    margin-bottom: 8px;
                    font-weight: 700;
                }

            .desc-box {
                background: var(--box-bg);
                border: 1px solid var(--border);
                color: #E0E0E0;
                padding: 16px;
                border-radius: 12px;
                font-size: 0.95rem;
                line-height: 1.6;
                min-height: 80px;
            }

            .empty-desc {
                color: #66667A;
                font-style: italic;
            }

            .btn-edit {
                display: block;
                width: 100%;
                padding: 14px;
                background: var(--primary);
                color: white;
                text-decoration: none;
                border-radius: 12px;
                font-size: 1rem;
                font-weight: 700;
                transition: background 0.3s ease;
                box-sizing: border-box;
            }

                .btn-edit:hover {
                    background: var(--primary-hover);
                }
        
            .btn-back {
                display: block;
                margin-top: 18px;
                color: var(--text-muted);
                text-decoration: none;
                font-size: 0.95rem;
                font-weight: 600;
                transition: color 0.3s ease;
            }

                .btn-back:hover {
                    color: #FFF;
                }
    </style>
</head>
<body>
    <div class="card">
        <div class="emoji-container">
            @(string.IsNullOrEmpty(Model.Emoji) ? "📁" : Model.Emoji)
        </div>

        <h2 class="category-name">@Model.NombreCategoria</h2>
        <div class="category-badge">Categoría</div>

        <div class="info-group">
            <label>Descripción</label>
            <div class="desc-box">
                @if (!string.IsNullOrEmpty(Model.Descripcion))
                {
                    @Model.Descripcion
                }
                else
                {
                    <span class="empty-desc">No hay descripción para esta categoría.</span>
                }
            </div>
        </div>

        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn-edit">✏️ Editar Categoría</a>
        
        <a asp-action="Index" asp-controller="Contactos" class="btn-back">Volver a la agenda</a>
    </div>
</body>
</html>