@model IEnumerable<ContactManagerWeb.Models.Categoria>

@{
    ViewData["Title"] = "Lista de Categorías";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">Gestión de Categorías</h2>
        <a asp-action="Crear" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nueva Categoría
        </a>
    </div>

    <div class="card bg-dark border-secondary">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr class="border-secondary">
                        <th>Nombre</th>
                        <th class="text-center">Emoji</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-secondary">
                            <td class="align-middle">@item.NombreCategoria</td>
                            <td class="text-center align-middle" style="font-size: 1.5rem;">@item.Emoji</td>
                            <td class="text-end">
                                <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-2">Editar</a>
                                <a asp-action="Eliminar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Contactos" asp-action="Index" class="btn btn-link text-muted text-decoration-none">
            ← Volver a la Agenda
        </a>
    </div>
</div>